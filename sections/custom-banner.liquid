<section class="eg-banner">
  <div class="eg-banner__top">
    <div class="eg-banner__logo">{{ section.settings.logo_text }}</div>
    <div class="eg-banner__tagline">{{ section.settings.top_text }}</div>
    <a href="{{ section.settings.button_link }}" class="eg-banner__top-btn">
      {{ section.settings.top_button }}
      <span>→</span>
    </a>
  </div>

  <div class="eg-banner__content">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.description }}</p>
    <a href="{{ section.settings.main_button_link }}" class="eg-banner__main-btn">
      {{ section.settings.main_button }}
      <span>→</span>
    </a>
  </div>

  <div class="eg-banner__bottom">
    {{ section.settings.bottom_text }}
  </div>
</section>

<style>
  .eg-banner {
    max-width: 1100px;
    margin: 0 auto;
    background: #fff;
    background-image: url({{ section.settings.banner_image | image_url: width: 1600 }});
    background-size: cover;
    background-position: center;
    min-height: 520px;
    position: relative;
    font-family: Arial, sans-serif;
    border: 1px solid #eee;
  }

  .eg-banner__top {
    height: 48px;
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    align-items: center;
    padding: 0 28px;
    border-bottom: 2px solid #f2c300;
    background: rgba(255,255,255,0.95);
    font-size: 13px;
  }

  .eg-banner__logo {
    font-weight: 700;
    letter-spacing: 1px;
  }

  .eg-banner__tagline {
    text-align: center;
    font-size: 11px;
  }

  .eg-banner__top-btn,
  .eg-banner__main-btn {
    background: #fff200;
    color: #000;
    text-decoration: none;
    font-weight: 700;
    transition: transform 0.25s ease;
  }

  .eg-banner__top-btn {
    padding: 14px 28px;
    font-size: 11px;
  }

  .eg-banner__main-btn {
    display: inline-flex;
    gap: 18px;
    align-items: center;
    background: #000;
    color: #fff;
    padding: 13px 34px;
    font-size: 11px;
    margin-top: 24px;
  }

  .eg-banner__top-btn:hover,
  .eg-banner__main-btn:hover {
    transform: translateY(-3px);
  }

  .eg-banner__content {
    width: 42%;
    padding: 190px 0 0 46px;
  }

  .eg-banner__content h1 {
    font-size: 48px;
    line-height: 1;
    margin: 0 0 18px;
    color: #000;
  }

  .eg-banner__content p {
    font-size: 13px;
    line-height: 1.6;
    color: #000;
    margin: 0;
  }

  .eg-banner__bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: #f7f7f7;
    text-align: center;
    padding: 8px;
    font-size: 10px;
    letter-spacing: 0.4px;
  }

  @media (max-width: 749px) {
    .eg-banner {
      min-height: 640px;
      background-position: center top;
    }

    .eg-banner__top {
      grid-template-columns: 1fr auto;
      padding: 0 16px;
    }

    .eg-banner__tagline {
      display: none;
    }

    .eg-banner__top-btn {
      padding: 13px 18px;
    }

    .eg-banner__content {
      width: auto;
      padding: 340px 24px 70px;
    }

    .eg-banner__content h1 {
      font-size: 38px;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner background image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "top_text",
      "label": "Top center text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "top_button",
      "label": "Top button text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Top button link"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "main_button",
      "label": "Main button text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "main_button_link",
      "label": "Main button link"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}