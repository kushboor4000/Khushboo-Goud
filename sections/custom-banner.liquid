{% schema %}
{
  "name": "Fixed Gift Guide Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Banner Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Banner Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Banner Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Banner Sub Text",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Fixed Banner (Desktop + Mobile)"
    }
  ]
}
{% endschema %}

<section class="fixed-banner">

  <!-- DESKTOP BANNER -->
  <div class="banner-desktop">
    <div class="banner-desktop-inner">
      <div class="banner-text">
        <h1>{{ section.settings.heading }}</h1>
        <p>{{ section.settings.subtext }}</p>
        <a href="{{ section.settings.button_link }}" class="banner-btn">
          {{ section.settings.button_text }} →
        </a>
      </div>

      {% if section.settings.desktop_image %}
        <div class="banner-image">
          <img
            src="{{ section.settings.desktop_image | image_url: width: 1600 }}"
            alt="Desktop Banner"
          >
        </div>
      {% endif %}
    </div>
  </div>

  <!-- MOBILE BANNER -->
  <div class="banner-mobile">
    {% if section.settings.mobile_image %}
      <img
        src="{{ section.settings.mobile_image | image_url: width: 900 }}"
        alt="Mobile Banner"
      >
    {% endif %}

    <div class="mobile-text">
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subtext }}</p>
      <a href="{{ section.settings.button_link }}" class="banner-btn">
        {{ section.settings.button_text }} →
      </a>
    </div>
  </div>

</section>

<style>
/* COMMON */
.fixed-banner {
  width: 100%;
  background: #fff;
}

.banner-btn {
  display: inline-block;
  background: #000;
  color: #fff;
  padding: 12px 26px;
  text-decoration: none;
  font-size: 14px;
}

/* ===================== */
/* DESKTOP ONLY */
/* ===================== */
.banner-desktop {
  display: block;
}

.banner-desktop-inner {
  max-width: 1200px;
  margin: auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 40px;
  padding: 60px 0;
}

.banner-text h1 {
  font-size: 48px;
  margin-bottom: 15px;
}

.banner-text p {
  font-size: 16px;
  margin-bottom: 25px;
}

.banner-image img {
  width: 100%;
  height: auto;
}

/* ===================== */
/* MOBILE ONLY */
/* ===================== */
.banner-mobile {
  display: none;
  text-align: center;
}

/* MOBILE IMAGE HEIGHT REDUCED ~30% */
.banner-mobile img {
  width: 100%;
  height: 280px;        /* 👈 height reduced */
  object-fit: cover;
}

.mobile-text {
  padding: 25px 20px 40px;
}

.mobile-text h1 {
  font-size: 32px;
  margin-bottom: 10px;
}

.mobile-text p {
  font-size: 14px;
  margin-bottom: 20px;
}

/* ===================== */
/* RESPONSIVE SWITCH */
/* ===================== */
@media (max-width: 768px) {
  .banner-desktop {
    display: none;
  }

  .banner-mobile {
    display: block;
  }
}
</style>
