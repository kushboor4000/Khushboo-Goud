{% schema %}
{
  "name": "Fixed Banner Final Lock",
  "settings": [
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop Image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile Image" },

    { "type": "text", "id": "desktop_heading", "label": "Desktop Heading", "default": "The Gift Guide" },
    { "type": "textarea", "id": "desktop_subtext", "label": "Desktop Sub Text", "default": "Discover Joy: Your Ultimate Holiday Gift\nDestination." },

    { "type": "text", "id": "mobile_heading", "label": "Mobile Heading", "default": "The Gift Guide" },
    { "type": "textarea", "id": "mobile_subtext", "label": "Mobile Sub Text", "default": "Discover Joy:\nYour Ultimate Holiday Gift\nDestination." },

    { "type": "text", "id": "button_text", "label": "Button Text", "default": "SHOP NOW" },
    { "type": "url", "id": "button_link", "label": "Button Link" }
  ],
  "presets": [{ "name": "Fixed Banner Final" }]
}
{% endschema %}

<section class="fixed-banner">

  <!-- ===== DESKTOP ===== -->
  <div class="banner-desktop">

    <div class="banner-above-text">
      <h1>{{ section.settings.desktop_heading }}</h1>
      <p class="banner-subtext">
        {{ section.settings.desktop_subtext }}
      </p>
    </div>

    {% if section.settings.desktop_image %}
    <div class="banner-image-wrap">
      <img src="{{ section.settings.desktop_image | image_url: width: 1600 }}" alt="">
      <a href="{{ section.settings.button_link }}" class="banner-btn inside">
        {{ section.settings.button_text }} →
      </a>
    </div>
    {% endif %}

  </div>

  <!-- ===== MOBILE ===== -->
  <div class="banner-mobile">

    <div class="banner-above-text">
      <h1>{{ section.settings.mobile_heading }}</h1>
      <p class="banner-subtext">
        {{ section.settings.mobile_subtext }}
      </p>
    </div>

    {% if section.settings.mobile_image %}
    <div class="banner-image-wrap">
      <img src="{{ section.settings.mobile_image | image_url: width: 900 }}" alt="">
      <a href="{{ section.settings.button_link }}" class="banner-btn inside">
        {{ section.settings.button_text }} →
      </a>
    </div>
    {% endif %}

  </div>

</section>

<style>
/* ===== COMMON ===== */
.fixed-banner {
  width: 100%;
  padding-top: 60px;
}

.banner-above-text {
  text-align: center;
}

.banner-above-text h1 {
  font-size: 48px;
}

.banner-subtext {
  margin-top: 18px;
  font-size: 16px;
  white-space: pre-line; /* 🔥 line break fix */
}

.banner-image-wrap {
  position: relative;
  margin-top: 25px;
}

.banner-btn.inside {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  background: #000;
  color: #fff;
  padding: 10px 24px; /* 👈 width thodi kam */
  font-size: 14px;
  text-decoration: none;
}

/* ===== DESKTOP ===== */
.banner-desktop {
  display: block;
  max-width: 1200px;
  margin: auto;
}

.banner-desktop img {
  width: 100%;
}

/* ===== MOBILE ===== */
.banner-mobile {
  display: none;
}

.banner-mobile img {
  width: 100%;
  height: 280px;
  object-fit: cover;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 768px) {
  .banner-desktop { display: none; }
  .banner-mobile { display: block; }

  .banner-above-text h1 {
    font-size: 32px;
  }

  .banner-subtext {
    font-size: 14px;
  }

  .banner-btn.inside {
    bottom: 15%;
  }
}

@media (min-width: 769px) {
  .banner-btn.inside {
    bottom: 30%;
  }
}
</style>
