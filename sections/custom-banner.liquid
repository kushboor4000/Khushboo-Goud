{% schema %}
{
  "name": "Fixed Gift Guide Banner",
  "settings": [
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop Banner Image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile Banner Image" },
    { "type": "text", "id": "heading", "label": "Banner Heading", "default": "The Gift Guide" },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Banner Sub Text",
      "default": "Discover Joy: Your Ultimate Holiday Gift\nDestination."
    },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "SHOP NOW" },
    { "type": "url", "id": "button_link", "label": "Button Link" }
  ],
  "presets": [{ "name": "Fixed Banner (Desktop + Mobile)" }]
}
{% endschema %}

<section class="fixed-banner">

  <!-- ================= DESKTOP ================= -->
  <div class="banner-desktop">
    <div class="banner-desktop-inner">

      <div class="banner-text">
        <h1>{{ section.settings.heading }}</h1>
        <p class="banner-subtext">{{ section.settings.subtext }}</p>
        <a href="{{ section.settings.button_link }}" class="banner-btn">
          {{ section.settings.button_text }} →
        </a>
      </div>

      {% if section.settings.desktop_image %}
        <div class="banner-image">
          <img src="{{ section.settings.desktop_image | image_url: width: 1600 }}" alt="">
        </div>
      {% endif %}

    </div>
  </div>

  <!-- ================= MOBILE ================= -->
  <div class="banner-mobile">

    <!-- 🍔 HAMBURGER ICON -->
    <div class="mobile-hamburger">
      <span></span>
      <span></span>
      <span></span>
    </div>

    {% if section.settings.mobile_image %}
      <img src="{{ section.settings.mobile_image | image_url: width: 900 }}" alt="">
    {% endif %}

    <div class="mobile-text">
      <h1>{{ section.settings.heading }}</h1>
      <p class="banner-subtext">{{ section.settings.subtext }}</p>
      <a href="{{ section.settings.button_link }}" class="banner-btn">
        {{ section.settings.button_text }} →
      </a>
    </div>
  </div>

</section>

<style>
/* ================= COMMON ================= */
.fixed-banner {
  width: 100%;
  background: #fff;
}

.banner-btn {
  display: inline-block;
  background: #000;
  color: #fff;
  padding: 12px 24px;
  font-size: 14px;
  text-decoration: none;
}

/* multiline text support */
.banner-subtext {
  white-space: pre-line;
  line-height: 1.4;
}

/* ================= DESKTOP ================= */
.banner-desktop {
  display: block;
}

.banner-desktop-inner {
  max-width: 1200px;
  margin: auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 40px;
  padding: 60px 0;
}

.banner-text h1 {
  font-size: 48px;
  margin-bottom: 15px;
}

.banner-text p {
  font-size: 16px;
  margin-bottom: 25px;
}

.banner-image img {
  width: 100%;
}

/* ================= MOBILE ================= */
.banner-mobile {
  display: none;
  position: relative;
  text-align: center;
}

.banner-mobile img {
  width: 100%;
  height: 280px;      /* height already reduced */
  object-fit: cover;
}

.mobile-text {
  padding: 25px 20px 40px;
}

.mobile-text h1 {
  font-size: 32px;
  margin-bottom: 10px;
}

.mobile-text p {
  font-size: 14px;
  margin-bottom: 20px;
}

/* 🍔 HAMBURGER STYLES */
.mobile-hamburger {
  position: absolute;
  top: 16px;
  right: 20px;
  width: 26px;
  cursor: pointer;
  z-index: 10;
}

.mobile-hamburger span {
  display: block;
  height: 3px;
  background: #000;
  margin: 6px 0;
  transition: 0.3s ease;
}

/* ❌ CROSS ANIMATION */
.mobile-hamburger.active span:nth-child(1) {
  transform: rotate(45deg) translate(6px, 6px);
}

.mobile-hamburger.active span:nth-child(2) {
  opacity: 0;
}

.mobile-hamburger.active span:nth-child(3) {
  transform: rotate(-45deg) translate(6px, -6px);
}

/* ================= RESPONSIVE ================= */
@media (max-width: 768px) {
  .banner-desktop {
    display: none;
  }

  .banner-mobile {
    display: block;
  }
}
</style>

<script>
/* 🍔 Hamburger toggle */
document.addEventListener("DOMContentLoaded", function () {
  const burger = document.querySelector(".mobile-hamburger");
  if (!burger) return;

  burger.addEventListener("click", function () {
    burger.classList.toggle("active");
  });
});
</script>
