<section class="eg-banner-wrap">

  <!-- DESKTOP BANNER -->
  <div class="eg-desktop-banner">
    <div class="eg-desktop-banner__top">
      <div class="eg-desktop-banner__logo">{{ section.settings.logo_text }}</div>

      <div class="eg-desktop-banner__tagline">
        {{ section.settings.top_text }}
      </div>

      <a href="{{ section.settings.button_link | default: '#' }}" class="eg-desktop-banner__choose">
        <span>{{ section.settings.top_button }}</span>
        <span class="eg-long-arrow"></span>
      </a>
    </div>

    {% if section.settings.desktop_top_image != blank %}
      <img
        class="eg-desktop-banner__top-img"
        src="{{ section.settings.desktop_top_image | image_url: width: 1800 }}"
        alt=""
        width="1440"
        height="390"
        loading="eager"
      >
    {% endif %}

    {% if section.settings.desktop_bottom_image != blank %}
      <img
        class="eg-desktop-banner__bottom-img"
        src="{{ section.settings.desktop_bottom_image | image_url: width: 1200 }}"
        alt=""
        width="890"
        height="402"
        loading="eager"
      >
    {% endif %}

    <div class="eg-desktop-banner__content">
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.desktop_description }}</p>
    </div>

    <a href="{{ section.settings.main_button_link | default: '#' }}" class="eg-desktop-banner__shop">
      {{ section.settings.main_button }} <span class="eg-long-arrow eg-long-arrow--white"></span>
    </a>

    <div class="eg-desktop-banner__strip">
      {{ section.settings.desktop_bottom_text }}
    </div>
  </div>

  <!-- MOBILE BANNER -->
  <div class="eg-mobile-banner">
    <div class="eg-mobile-menu" id="EgMobileMenu">
      <p>{{ section.settings.mobile_menu_text }}</p>
      <a href="{{ section.settings.button_link | default: '#' }}">
        {{ section.settings.top_button }} <span class="eg-long-arrow"></span>
      </a>
    </div>

    <div class="eg-mobile-banner__top">
      <button type="button" class="eg-mobile-banner__hamburger" id="EgMenuToggle">☰</button>
      <div class="eg-mobile-banner__logo">{{ section.settings.logo_text }}</div>
      <div></div>
    </div>

    <div class="eg-mobile-banner__content">
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.mobile_description }}</p>
    </div>

    <a href="{{ section.settings.main_button_link | default: '#' }}" class="eg-mobile-banner__shop">
      {{ section.settings.main_button }} <span class="eg-long-arrow eg-long-arrow--white"></span>
    </a>

    <div class="eg-mobile-banner__strip">
      {{ section.settings.mobile_bottom_text }}
    </div>
  </div>

</section>

<style>
@import url('https://fonts.googleapis.com/css2?family=Jost:wght@400;500;600;700&display=swap');

.eg-banner-wrap,
.eg-banner-wrap * {
  font-family: 'Jost', Arial, Helvetica, sans-serif;
  box-sizing: border-box;
}

.eg-banner-wrap {
  width: 100%;
  background: #000;
}

/* Arrow */
.eg-long-arrow {
  position: relative;
  display: inline-block;
  width: 28px;
  height: 1px;
  background: currentColor;
  vertical-align: middle;
}

.eg-long-arrow::after {
  content: "";
  position: absolute;
  right: 0;
  top: -4px;
  width: 8px;
  height: 8px;
  border-top: 1px solid currentColor;
  border-right: 1px solid currentColor;
  transform: rotate(45deg);
}

.eg-long-arrow--white {
  color: #fff;
}

/* DESKTOP */
.eg-desktop-banner {
  display: block;
  width: 100%;
  max-width: 1440px;
  height: 876px;
  margin: 0 auto;
  position: relative;
  overflow: hidden;
  background: #fff;
  color: #000;
}

.eg-desktop-banner__top {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  min-height: 64px;
  padding: 10px 140px;
  background: #f7f7f7;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  column-gap: 360px;
  z-index: 20;
}

.eg-desktop-banner__logo {
  font-size: 24px;
  line-height: 1;
  font-weight: 700;
  letter-spacing: 0.2px;
  white-space: nowrap;
}

.eg-desktop-banner__tagline {
  font-size: 16px;
  line-height: 1.2;
  font-weight: 400;
  text-align: center;
  white-space: nowrap;
}

.eg-desktop-banner__choose {
  justify-self: end;
  width: 205px;
  height: 44px;
  background: #fff544;
  color: #000;
  text-decoration: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24px;
  font-size: 16px;
  line-height: 1;
  font-weight: 400;
  letter-spacing: -0.2px;
  position: relative;
  overflow: hidden;
}

.eg-desktop-banner__choose::before {
  content: "";
  position: absolute;
  inset: 0;
  background: #000;
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.35s ease;
  z-index: 1;
}

.eg-desktop-banner__choose:hover::before {
  transform: scaleX(1);
}

.eg-desktop-banner__choose span {
  position: relative;
  z-index: 2;
  transition: color 0.25s ease;
}

.eg-desktop-banner__choose:hover span {
  color: #fff;
}

.eg-desktop-banner__top-img {
  position: absolute;
  top: 64px;
  left: 0;
  width: 1440px;
  height: 390px;
  object-fit: cover;
  object-position: center top;
  z-index: 1;
}

.eg-desktop-banner__bottom-img {
  position: absolute;
  top: 442px;
  left: 550px;
  width: 890px;
  height: 402px;
  object-fit: cover;
  object-position: center top;
  z-index: 1;
}

.eg-desktop-banner__content {
  position: absolute;
  left: 67px;
  top: 492px;
  width: 590px;
  z-index: 10;
}

.eg-desktop-banner__content h1 {
  margin: 0 0 28px;
  font-size: 70px;
  line-height: 1;
  font-weight: 500;
  color: #000;
}

.eg-desktop-banner__content p {
  margin: 0;
  width: 610px;
  max-width: 610px;
  font-size: 20px;
  line-height: 140%;
  font-weight: 400;
  color: #000;
  letter-spacing: -0.15px;
}

.eg-desktop-banner__shop {
  position: absolute;
  top: 743px;
  left: 67px;
  width: 220px;
  height: 50px;
  background: #000;
  color: #fff;
  text-decoration: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 36px;
  font-size: 14px;
  line-height: 1;
  font-weight: 400;
  letter-spacing: -0.2px;
  z-index: 10;
}

.eg-desktop-banner__strip {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 32px;
  background: #f4f4f4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  line-height: 1;
  font-weight: 400;
  color: #000;
  z-index: 15;
}

/* MOBILE */
.eg-mobile-banner {
  display: none;
}

@media (max-width: 749px) {
  .eg-desktop-banner {
    display: none;
  }

  .eg-mobile-banner {
    display: block;
    width: 100%;
    height: 487px;
    position: relative;
    overflow: hidden;
    background: #fff;
    color: #000;
  }

  .eg-mobile-banner::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 205px;
    height: 245px;
    background-image: url({{ section.settings.mobile_banner_image | image_url: width: 900 }});
    background-size: 100% auto;
    background-position: center top;
    background-repeat: no-repeat;
    z-index: 1;
  }

  .eg-mobile-banner__top {
    height: 45px;
    display: grid;
    grid-template-columns: 32px 1fr 32px;
    align-items: center;
    padding: 0 20px;
    background: #f7f7f7;
    position: relative;
    z-index: 20;
  }

  .eg-mobile-banner__hamburger {
    border: 0;
    background: transparent;
    font-size: 22px;
    padding: 0;
    color: #000;
    cursor: pointer;
    font-family: inherit;
  }

  .eg-mobile-banner__logo {
    text-align: center;
    font-size: 21px;
    line-height: 1;
    font-weight: 700;
    letter-spacing: 0.2px;
  }

  .eg-mobile-banner__content {
    position: absolute;
    top: 92px;
    left: 24px;
    right: 24px;
    text-align: center;
    z-index: 5;
  }

  .eg-mobile-banner__content h1 {
    margin: 0 0 18px;
    font-size: 30px;
    line-height: 1.1;
    font-weight: 700;
  }

  .eg-mobile-banner__content p {
    max-width: 285px;
    margin: 0 auto;
    font-size: 14px;
    line-height: 1.35;
    font-weight: 400;
  }

  .eg-mobile-banner__shop {
    position: absolute;
    left: 50%;
    top: 380px;
    transform: translateX(-50%);
    width: 180px;
    height: 48px;
    background: #000;
    color: #fff;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 30px;
    font-size: 15px;
    z-index: 10;
  }

  .eg-mobile-banner__strip {
    position: absolute;
    left: 0;
    right: 0;
    top: 455px;
    height: 32px;
    background: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    z-index: 10;
  }

  .eg-mobile-menu {
    position: absolute;
    top: 45px;
    left: 0;
    right: 0;
    background: #f7f7f7;
    padding: 20px 20px 26px;
    text-align: center;
    z-index: 30;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: opacity .25s ease, transform .25s ease, visibility .25s ease;
  }

  .eg-mobile-menu.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .eg-mobile-menu p {
    margin: 0 0 14px;
    font-size: 14px;
  }

  .eg-mobile-menu a {
    width: 244px;
    height: 48px;
    margin: 0 auto;
    background: #fff544;
    color: #000;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 34px;
    font-size: 15px;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var btn = document.getElementById('EgMenuToggle');
  var menu = document.getElementById('EgMobileMenu');

  if (btn && menu) {
    btn.addEventListener('click', function () {
      menu.classList.toggle('is-open');
      btn.textContent = menu.classList.contains('is-open') ? '×' : '☰';
    });
  }
});
</script>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_top_image",
      "label": "Desktop top image"
    },
    {
      "type": "image_picker",
      "id": "desktop_bottom_image",
      "label": "Desktop bottom image"
    },
    {
      "type": "image_picker",
      "id": "desktop_banner_image",
      "label": "Desktop single fallback image"
    },
    {
      "type": "image_picker",
      "id": "mobile_banner_image",
      "label": "Mobile banner image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "top_text",
      "label": "Desktop top text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "top_button",
      "label": "Top button text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Top button link"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "desktop_description",
      "label": "Desktop description",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "textarea",
      "id": "mobile_description",
      "label": "Mobile description",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination."
    },
    {
      "type": "text",
      "id": "main_button",
      "label": "Main button text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "main_button_link",
      "label": "Main button link"
    },
    {
      "type": "text",
      "id": "desktop_bottom_text",
      "label": "Desktop bottom text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
      "type": "text",
      "id": "mobile_bottom_text",
      "label": "Mobile bottom text",
      "default": "SUSTAINABLE, ETHICALLY MADE ACTIVEWEAR"
    },
    {
      "type": "text",
      "id": "mobile_menu_text",
      "label": "Mobile menu text",
      "default": "Find the ideal gift for your loved ones."
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}
