{% schema %}
{
  "name": "Custom Gift Guide Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sub Text",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination."
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Illustration Image"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Gift Guide Banner"
    }
  ]
}
{% endschema %}

<section class="gift-banner">
  <div class="gift-banner__inner">
    
    <div class="gift-banner__content">
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subtext }}</p>

      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="gift-btn">
          {{ section.settings.button_text }} →
        </a>
      {% endif %}
    </div>

    {% if section.settings.banner_image %}
      <div class="gift-banner__image">
        <img
          src="{{ section.settings.banner_image | image_url: width: 1600 }}"
          alt="Gift Guide Banner"
          loading="lazy"
        >
      </div>
    {% endif %}

  </div>
</section>

<style>
.gift-banner {
  background: #fff;
  padding: 60px 0;
}

.gift-banner__inner {
  max-width: 1200px;
  margin: auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: center;
}

.gift-banner__content h1 {
  font-size: 48px;
  font-weight: 700;
  margin-bottom: 15px;
}

.gift-banner__content p {
  font-size: 16px;
  color: #555;
  margin-bottom: 25px;
}

.gift-btn {
  display: inline-block;
  background: #000;
  color: #fff;
  padding: 12px 28px;
  text-decoration: none;
  font-size: 14px;
  letter-spacing: 1px;
}

.gift-banner__image img {
  width: 100%;
  height: auto;
}

/* 🔹 Mobile Fix */
@media (max-width: 768px) {
  .gift-banner__inner {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .gift-banner__content h1 {
    font-size: 34px;
  }
}
</style>
