{% schema %}
{
  "name": "Fixed Banner (Desktop + Mobile Separate)",
  "settings": [
    { "type": "header", "content": "DESKTOP CONTENT" },

    { "type": "image_picker", "id": "desktop_image", "label": "Desktop Image" },
    { "type": "text", "id": "desktop_heading", "label": "Desktop Heading", "default": "The Gift Guide" },
    { "type": "textarea", "id": "desktop_subtext", "label": "Desktop Sub Text", "default": "Discover Joy: Your Ultimate Holiday Gift Destination." },
    { "type": "text", "id": "desktop_button_text", "label": "Desktop Button Text", "default": "SHOP NOW" },
    { "type": "url", "id": "desktop_button_link", "label": "Desktop Button Link" },

    { "type": "header", "content": "MOBILE CONTENT" },

    { "type": "image_picker", "id": "mobile_image", "label": "Mobile Image" },
    { "type": "text", "id": "mobile_heading", "label": "Mobile Heading", "default": "The Gift Guide" },
    { "type": "textarea", "id": "mobile_subtext", "label": "Mobile Sub Text", "default": "Discover Joy: Your Ultimate Holiday Gift Destination." },
    { "type": "text", "id": "mobile_button_text", "label": "Mobile Button Text", "default": "SHOP NOW" },
    { "type": "url", "id": "mobile_button_link", "label": "Mobile Button Link" }
  ],
  "presets": [
    { "name": "Fixed Banner – Separate Desktop & Mobile" }
  ]
}
{% endschema %}

<section class="fixed-banner">

  <!-- DESKTOP -->
  <div class="banner-desktop">
    <div class="banner-inner">
      <div class="banner-text">
        <h1>{{ section.settings.desktop_heading }}</h1>
        <p>{{ section.settings.desktop_subtext }}</p>
        <a href="{{ section.settings.desktop_button_link }}" class="banner-btn">
          {{ section.settings.desktop_button_text }} →
        </a>
      </div>

      {% if section.settings.desktop_image %}
        <img src="{{ section.settings.desktop_image | image_url: width: 1600 }}" alt="">
      {% endif %}
    </div>
  </div>

  <!-- MOBILE -->
  <div class="banner-mobile">
    {% if section.settings.mobile_image %}
      <img src="{{ section.settings.mobile_image | image_url: width: 900 }}" alt="">
    {% endif %}

    <div class="mobile-text">
      <h1>{{ section.settings.mobile_heading }}</h1>
      <p>{{ section.settings.mobile_subtext }}</p>
      <a href="{{ section.settings.mobile_button_link }}" class="banner-btn">
        {{ section.settings.mobile_button_text }} →
      </a>
    </div>
  </div>

</section>

<style>
.fixed-banner { width:100%; }

.banner-btn {
  background:#000;
  color:#fff;
  padding:12px 26px;
  text-decoration:none;
  font-size:14px;
}

/* DESKTOP */
.banner-desktop { display:block; }
.banner-inner {
  max-width:1200px;
  margin:auto;
  display:grid;
  grid-template-columns:1fr 1fr;
  align-items:center;
  gap:40px;
  padding:60px 0;
}

/* MOBILE */
.banner-mobile { display:none; text-align:center; }
.banner-mobile img {
  width:100%;
  height:280px;
  object-fit:cover;
}
.mobile-text { padding:25px 20px 40px; }

/* RESPONSIVE */
@media(max-width:768px){
  .banner-desktop{ display:none; }
  .banner-mobile{ display:block; }
}
</style>
