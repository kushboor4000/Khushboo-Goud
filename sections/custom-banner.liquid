<section class="eg-banner-wrap">
  <div class="eg-desktop-banner">
    <div class="eg-desktop-banner__top">
      <div class="eg-desktop-banner__logo">{{ section.settings.logo_text }}</div>

      <div class="eg-desktop-banner__tagline">
        {{ section.settings.top_text }}
      </div>

      <a href="{{ section.settings.button_link | default: '#' }}" class="eg-desktop-banner__choose eg-animated-btn">
        <span>{{ section.settings.top_button }}</span>
        <span class="eg-long-arrow"></span>
      </a>
    </div>

    {% if section.settings.desktop_top_image != blank %}
      <img class="eg-desktop-banner__top-img"
        src="{{ section.settings.desktop_top_image | image_url: width: 1800 }}"
        alt="{{ section.settings.heading | escape }}"
        width="1440"
        height="390"
        loading="eager">
    {% endif %}

    {% if section.settings.desktop_bottom_image != blank %}
      <img class="eg-desktop-banner__bottom-img"
        src="{{ section.settings.desktop_bottom_image | image_url: width: 1200 }}"
        alt="{{ section.settings.heading | escape }}"
        width="890"
        height="402"
        loading="eager">
    {% endif %}

    <div class="eg-desktop-banner__content">
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.desktop_description | newline_to_br }}</p>
    </div>

    <a href="{{ section.settings.main_button_link | default: '#' }}" class="eg-desktop-banner__shop eg-animated-btn eg-animated-btn--dark">
      <span>{{ section.settings.main_button }}</span>
      <span class="eg-long-arrow"></span>
    </a>

    <div class="eg-desktop-banner__strip">
      {{ section.settings.desktop_bottom_text }}
    </div>
  </div>

  <div class="eg-mobile-banner">
    <div class="eg-mobile-menu" id="EgMobileMenu-{{ section.id }}">
      <p>{{ section.settings.mobile_menu_text }}</p>
      <a href="{{ section.settings.button_link | default: '#' }}" class="eg-animated-btn">
        <span>{{ section.settings.top_button }}</span>
        <span class="eg-long-arrow"></span>
      </a>
    </div>

    <div class="eg-mobile-banner__top">
      <button type="button" class="eg-mobile-banner__hamburger" id="EgMenuToggle-{{ section.id }}" aria-label="Open menu">☰</button>
      <div class="eg-mobile-banner__logo">{{ section.settings.logo_text }}</div>
      <div></div>
    </div>

    <div class="eg-mobile-banner__content">
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.mobile_description }}</p>
    </div>

    <a href="{{ section.settings.main_button_link | default: '#' }}" class="eg-mobile-banner__shop eg-animated-btn eg-animated-btn--dark">
      <span>{{ section.settings.main_button }}</span>
      <span class="eg-long-arrow"></span>
    </a>

    <div class="eg-mobile-banner__strip">
      {{ section.settings.mobile_bottom_text }}
    </div>
  </div>
</section>

<style>
.eg-banner-wrap,
.eg-banner-wrap * {
  box-sizing: border-box;
  font-family: Jost, Arial, Helvetica, sans-serif;
}

.eg-banner-wrap {
  width: 100%;
  background: #fff;
}

.eg-long-arrow {
  position: relative;
  display: inline-block;
  width: 32px;
  height: 1px;
  background: currentColor;
}

.eg-long-arrow::after {
  content: "";
  position: absolute;
  right: 0;
  top: -4px;
  width: 8px;
  height: 8px;
  border-top: 1px solid currentColor;
  border-right: 1px solid currentColor;
  transform: rotate(45deg);
}

.eg-animated-btn {
  position: relative;
  overflow: hidden;
  isolation: isolate;
}

.eg-animated-btn::before {
  content: "";
  position: absolute;
  inset: 0;
  background: #000;
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .35s ease;
  z-index: -1;
}

.eg-animated-btn:hover::before {
  transform: scaleX(1);
}

.eg-animated-btn:hover {
  color: #fff;
}

.eg-animated-btn--dark::before {
  background: #fff544;
}

.eg-animated-btn--dark:hover {
  color: #000;
}

.eg-desktop-banner {
  max-width: 1440px;
  height: 876px;
  margin: 0 auto;
  position: relative;
  overflow: hidden;
  background: #fff;
  color: #000;
}

.eg-desktop-banner__top {
  position: absolute;
  inset: 0 auto auto 0;
  width: 100%;
  min-height: 64px;
  padding: 10px 67px;
  background: #f7f7f7;
  display: grid;
  grid-template-columns: 220px 1fr 220px;
  align-items: center;
  z-index: 5;
}

.eg-desktop-banner__logo {
  font-size: 24px;
  font-weight: 700;
}

.eg-desktop-banner__tagline {
  text-align: center;
  font-size: 16px;
}

.eg-desktop-banner__choose {
  width: 220px;
  height: 44px;
  justify-self: end;
  background: #fff544;
  color: #000;
  text-decoration: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 26px;
  font-size: 16px;
}

.eg-desktop-banner__top-img {
  position: absolute;
  top: 64px;
  left: 0;
  width: 100%;
  height: 390px;
  object-fit: cover;
}

.eg-desktop-banner__bottom-img {
  position: absolute;
  top: 442px;
  right: 0;
  width: 890px;
  height: 402px;
  object-fit: cover;
}

.eg-desktop-banner__content {
  position: absolute;
  left: 67px;
  top: 492px;
  width: 650px;
  z-index: 2;
}

.eg-desktop-banner__content h1 {
  margin: 0 0 28px;
  font-size: 70px;
  line-height: 1;
  font-weight: 500;
}

.eg-desktop-banner__content p {
  margin: 0;
  max-width: 540px;
  font-size: 20px;
  line-height: 1.4;
}

.eg-desktop-banner__shop {
  position: absolute;
  left: 67px;
  top: 735px;
  width: 220px;
  height: 50px;
  background: #000;
  color: #fff;
  text-decoration: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 36px;
  font-size: 14px;
  z-index: 3;
}

.eg-desktop-banner__strip,
.eg-mobile-banner__strip {
  background: #f4f4f4;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #000;
}

.eg-desktop-banner__strip {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 32px;
  font-size: 14px;
}

.eg-mobile-banner {
  display: none;
}

@media (max-width: 749px) {
  .eg-desktop-banner {
    display: none;
  }

  .eg-mobile-banner {
    display: block;
    height: 487px;
    position: relative;
    overflow: hidden;
    background: #fff;
    color: #000;
  }

  .eg-mobile-banner::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 205px;
    height: 245px;
    background-image: url({{ section.settings.mobile_banner_image | image_url: width: 900 }});
    background-size: 100% auto;
    background-position: center top;
    background-repeat: no-repeat;
  }

  .eg-mobile-banner__top {
    height: 45px;
    display: grid;
    grid-template-columns: 32px 1fr 32px;
    align-items: center;
    padding: 0 20px;
    background: #f7f7f7;
    position: relative;
    z-index: 3;
  }

  .eg-mobile-banner__hamburger {
    border: 0;
    background: transparent;
    font-size: 22px;
    padding: 0;
    color: #000;
  }

  .eg-mobile-banner__logo {
    text-align: center;
    font-size: 21px;
    font-weight: 700;
  }

  .eg-mobile-banner__content {
    position: absolute;
    top: 92px;
    left: 24px;
    right: 24px;
    text-align: center;
    z-index: 2;
  }

  .eg-mobile-banner__content h1 {
    margin: 0 0 18px;
    font-size: 30px;
    line-height: 1.1;
  }

  .eg-mobile-banner__content p {
    max-width: 285px;
    margin: 0 auto;
    font-size: 14px;
    line-height: 1.35;
  }

  .eg-mobile-banner__shop {
    position: absolute;
    left: 50%;
    top: 380px;
    transform: translateX(-50%);
    width: 180px;
    height: 48px;
    background: #000;
    color: #fff;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 30px;
    font-size: 15px;
    z-index: 2;
  }

  .eg-mobile-banner__strip {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 32px;
    font-size: 11px;
    z-index: 2;
  }

  .eg-mobile-menu {
    position: absolute;
    top: 45px;
    left: 0;
    right: 0;
    background: #f7f7f7;
    padding: 20px;
    text-align: center;
    z-index: 10;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: .25s ease;
  }

  .eg-mobile-menu.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .eg-mobile-menu a {
    width: 244px;
    height: 48px;
    margin: 0 auto;
    background: #fff544;
    color: #000;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 34px;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const btn = document.getElementById('EgMenuToggle-{{ section.id }}');
  const menu = document.getElementById('EgMobileMenu-{{ section.id }}');

  if (!btn || !menu) return;

  btn.addEventListener('click', function () {
    const isOpen = menu.classList.toggle('is-open');
    btn.textContent = isOpen ? '×' : '☰';
    btn.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
  });
});
</script>

{% schema %}
{
  "name": "EG Custom Banner",
  "settings": [
    { "type": "image_picker", "id": "desktop_top_image", "label": "Desktop top image" },
    { "type": "image_picker", "id": "desktop_bottom_image", "label": "Desktop bottom image" },
    { "type": "image_picker", "id": "mobile_banner_image", "label": "Mobile banner image" },
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "TISSO VISON" },
    { "type": "text", "id": "top_text", "label": "Top text", "default": "Find the ideal gift for your loved ones." },
    { "type": "text", "id": "top_button", "label": "Top button text", "default": "CHOOSE GIFT" },
    { "type": "url", "id": "button_link", "label": "Top button link" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Gift Guide" },
    { "type": "textarea", "id": "desktop_description", "label": "Desktop description", "default": "Discover Joy: Your Ultimate Holiday Gift Destination.\nExplore our curated selection and find the perfect gifts to\ndelight your loved ones this holiday season." },
    { "type": "textarea", "id": "mobile_description", "label": "Mobile description", "default": "Discover Joy: Your Ultimate Holiday Gift Destination." },
    { "type": "text", "id": "main_button", "label": "Main button text", "default": "SHOP NOW" },
    { "type": "url", "id": "main_button_link", "label": "Main button link" },
    { "type": "text", "id": "desktop_bottom_text", "label": "Desktop bottom text", "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL" },
    { "type": "text", "id": "mobile_bottom_text", "label": "Mobile bottom text", "default": "SUSTAINABLE, ETHICALLY MADE ACTIVEWEAR" },
    { "type": "text", "id": "mobile_menu_text", "label": "Mobile menu text", "default": "Find the ideal gift for your loved ones." }
  ],
  "presets": [
    { "name": "EG Custom Banner" }
  ]
}
{% endschema %}
