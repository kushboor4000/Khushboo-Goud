<section class="tisso-banner">
  <div class="tisso-mobile-menu" id="TissoMobileMenu">
    <button type="button" class="tisso-mobile-menu__close" id="TissoMenuClose">×</button>
    <div class="tisso-mobile-menu__logo">{{ section.settings.logo_text }}</div>
    <p>{{ section.settings.top_text }}</p>
    <a href="{{ section.settings.top_button_link | default: '#' }}">
      {{ section.settings.top_button }} <span>→</span>
    </a>
  </div>

  <div class="tisso-banner__top">
    <button type="button" class="tisso-banner__hamburger" id="TissoMenuOpen">☰</button>
    <div class="tisso-banner__logo">{{ section.settings.logo_text }}</div>
    <div class="tisso-banner__tagline">{{ section.settings.top_text }}</div>
    <a href="{{ section.settings.top_button_link | default: '#' }}" class="tisso-banner__choose">
      {{ section.settings.top_button }} <span>→</span>
    </a>
  </div>

  <div class="tisso-banner__content">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.description }}</p>
  </div>

  <a href="{{ section.settings.main_button_link | default: '#' }}" class="tisso-banner__shop">
    {{ section.settings.main_button }} <span>→</span>
  </a>

  <div class="tisso-banner__strip">
    {{ section.settings.bottom_text }}
  </div>
</section>

<style>
.tisso-banner {
  width: 100%;
  max-width: 1440px;
  height: 520px;
  margin: 0 auto;
  position: relative;
  overflow: hidden;
  font-family: Arial, Helvetica, sans-serif;
  color: #000;
  background-color: #fff;
  background-image: url({{ section.settings.desktop_banner | image_url: width: 1800 }});
  background-size: cover;
  background-position: center top;
  background-repeat: no-repeat;
}

.tisso-banner__top {
  height: 56px;
  display: grid;
  grid-template-columns: 1fr 1fr 190px;
  align-items: center;
  padding: 0 52px;
  background: #fff;
  box-sizing: border-box;
  position: relative;
  z-index: 3;
}

.tisso-banner__hamburger {
  display: none;
}

.tisso-banner__logo {
  font-size: 18px;
  font-weight: 700;
  letter-spacing: .5px;
}

.tisso-banner__tagline {
  text-align: center;
  font-size: 12px;
}

.tisso-banner__choose {
  height: 44px;
  background: #fff544;
  color: #000;
  text-decoration: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28px;
  font-size: 12px;
  font-weight: 500;
}

.tisso-banner__content {
  position: absolute;
  left: 64px;
  top: 250px;
  width: 430px;
  z-index: 2;
}

.tisso-banner__content h1 {
  margin: 0 0 22px;
  font-size: 52px;
  line-height: 1;
  font-weight: 700;
}

.tisso-banner__content p {
  margin: 0;
  max-width: 380px;
  font-size: 14px;
  line-height: 1.4;
}

.tisso-banner__shop {
  position: absolute;
  left: 64px;
  top: 390px;
  width: 180px;
  height: 48px;
  background: #000;
  color: #fff;
  text-decoration: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 34px;
  font-size: 12px;
  z-index: 4;
}

.tisso-banner__strip {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 30px;
  background: #f4f4f4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  text-align: center;
  z-index: 4;
}

.tisso-mobile-menu {
  display: none;
}

@media screen and (max-width: 749px) {
  .tisso-banner {
    height: 445px;
    background-image: url({{ section.settings.mobile_banner | image_url: width: 900 }});
    background-size: 160% auto;
    background-position: center 178px;
    background-repeat: no-repeat;
  }

  .tisso-banner__top {
    height: 54px;
    grid-template-columns: 28px 1fr 28px;
    padding: 0 20px;
    background: #fff;
  }

  .tisso-banner__hamburger {
    display: block;
    border: 0;
    background: transparent;
    font-size: 20px;
    color: #000;
    padding: 0;
    cursor: pointer;
  }

  .tisso-banner__logo {
    text-align: center;
    font-size: 20px;
    font-weight: 700;
  }

  .tisso-banner__tagline,
  .tisso-banner__choose {
    display: none;
  }

  .tisso-banner__content h1 {
    font-size: 24px;
    line-height: 1.1;
    margin: 0 0 14px;
  }

  .tisso-banner__content p {
    max-width: 255px;
    margin: 0 auto;
    font-size: 11px;
    line-height: 1.35;
  }

  .tisso-banner__shop {
    top: 318px;
    left: 50%;
    transform: translateX(-50%);
    width: 178px;
    height: 44px;
    gap: 34px;
    font-size: 12px;
  }

  .tisso-banner__strip {
    bottom: 0;
    height: 24px;
    font-size: 8px;
  }

  .tisso-mobile-menu {
    display: none;
    position: absolute;
    top: 54px;
    left: 0;
    right: 0;
    background: #f4f4f4;
    padding: 16px 20px 22px;
    text-align: center;
    z-index: 20;
    box-shadow: 0 4px 10px rgba(0,0,0,.08);
  }

  .tisso-mobile-menu.is-open {
    display: block;
  }

  .tisso-mobile-menu__close {
    position: absolute;
    left: 20px;
    top: 15px;
    border: 0;
    background: transparent;
    font-size: 24px;
    cursor: pointer;
  }

  .tisso-mobile-menu__logo {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 24px;
  }

  .tisso-mobile-menu p {
    margin: 0 0 14px;
    font-size: 12px;
  }

  .tisso-mobile-menu a {
    width: 210px;
    height: 44px;
    margin: 0 auto;
    background: #fff544;
    color: #000;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 36px;
    font-size: 12px;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var openBtn = document.getElementById('TissoMenuOpen');
  var closeBtn = document.getElementById('TissoMenuClose');
  var menu = document.getElementById('TissoMobileMenu');

  if (openBtn && closeBtn && menu) {
    openBtn.addEventListener('click', function () {
      menu.classList.add('is-open');
    });

    closeBtn.addEventListener('click', function () {
      menu.classList.remove('is-open');
    });
  }
});
</script>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_banner",
      "label": "Desktop banner image"
    },
    {
      "type": "image_picker",
      "id": "mobile_banner",
      "label": "Mobile banner image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "top_text",
      "label": "Top text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "top_button",
      "label": "Top button text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "top_button_link",
      "label": "Top button link"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "main_button",
      "label": "Main button text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "main_button_link",
      "label": "Main button link"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom strip text",
      "default": "SUSTAINABLE, ETHICALLY MADE ACTIVEWEAR"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}
