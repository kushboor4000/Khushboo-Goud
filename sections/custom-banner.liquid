<section class="eg-banner">
  <div class="eg-mobile-menu" id="EgMobileMenu">
    <p>{{ section.settings.mobile_menu_text }}</p>
    <a href="{{ section.settings.button_link | default: '#' }}">
      {{ section.settings.top_button }} <span>→</span>
    </a>
  </div>

  <div class="eg-banner__top">
    <button type="button" class="eg-banner__hamburger" id="EgMenuToggle">☰</button>

    <div class="eg-banner__logo">{{ section.settings.logo_text }}</div>

    <div class="eg-banner__tagline">{{ section.settings.top_text }}</div>

    <a href="{{ section.settings.button_link | default: '#' }}" class="eg-banner__top-btn">
      {{ section.settings.top_button }} <span>→</span>
    </a>
  </div>

  <div class="eg-banner__content">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.description }}</p>
  </div>

  <a href="{{ section.settings.main_button_link | default: '#' }}" class="eg-banner__main-btn">
    {{ section.settings.main_button }} <span>→</span>
  </a>

  <div class="eg-banner__bottom">
    {{ section.settings.bottom_text }}
  </div>
</section>

<style>
.eg-banner {
  width: 100%;
  max-width: 1440px;
  height: 843px;
  margin: 0 auto;
  position: relative;
  overflow: hidden;
  background: #fff url({{ section.settings.desktop_banner_image | image_url: width: 1800 }}) center top / 100% auto no-repeat;
  font-family: Arial, Helvetica, sans-serif;
  color: #000;
}

.eg-banner__top {
  height: 48px;
  display: grid;
  grid-template-columns: 1fr 1fr 205px;
  align-items: center;
  padding: 0 140px;
  background: #fff;
  box-sizing: border-box;
  position: relative;
  z-index: 20;
}

.eg-banner__hamburger {
  display: none;
}

.eg-banner__logo {
  font-size: 16px;
  font-weight: 700;
  letter-spacing: .4px;
}

.eg-banner__tagline {
  text-align: center;
  font-size: 14px;
  font-weight: 400;
}

.eg-banner__top-btn {
  height: 44px;
  background: #fff544;
  color: #000;
  text-decoration: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30px;
  font-size: 14px;
  font-weight: 400;
}

.eg-banner__content {
  position: absolute;
  left: 140px;
  top: 462px;
  width: 460px;
  z-index: 5;
}

.eg-banner__content h1 {
  margin: 0 0 34px;
  font-size: 56px;
  line-height: 1;
  font-weight: 700;
}

.eg-banner__content p {
  margin: 0;
  max-width: 430px;
  font-size: 16px;
  line-height: 1.45;
}

.eg-banner__main-btn {
  position: absolute;
  left: 140px;
  top: 662px;
  width: 196px;
  height: 45px;
  background: #000;
  color: #fff;
  text-decoration: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 34px;
  font-size: 13px;
  z-index: 5;
}

.eg-banner__bottom {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 32px;
  background: #f4f4f4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
}

.eg-mobile-menu {
  display: none;
}

@media (max-width: 749px) {
  .eg-banner {
    height: 520px;
    background-image: url({{ section.settings.mobile_banner_image | image_url: width: 900 }});
    background-size: 100% auto;
    background-position: center top;
  }

  .eg-banner__top {
    height: 64px;
    grid-template-columns: 32px 1fr 32px;
    padding: 0 20px;
    background: #f4f4f4;
  }

  .eg-banner__hamburger {
    display: block;
    border: 0;
    background: transparent;
    font-size: 24px;
    line-height: 1;
    padding: 0;
    color: #000;
    cursor: pointer;
    z-index: 40;
  }

  .eg-banner__logo {
    text-align: center;
    font-size: 22px;
    font-weight: 700;
  }

  .eg-banner__tagline,
  .eg-banner__top-btn {
    display: none;
  }

  .eg-banner__content {
    top: 116px;
    left: 24px;
    right: 24px;
    width: auto;
    text-align: center;
  }

  .eg-banner__content h1 {
    font-size: 30px;
    line-height: 1.1;
    margin: 0 0 24px;
  }

  .eg-banner__content p {
    max-width: 285px;
    margin: 0 auto;
    font-size: 14px;
    line-height: 1.35;
  }

  .eg-banner__main-btn {
    left: 50%;
    top: 384px;
    transform: translateX(-50%);
    width: 190px;
    height: 48px;
    gap: 34px;
    font-size: 15px;
  }

  .eg-banner__bottom {
    height: 32px;
    font-size: 11px;
  }

  .eg-mobile-menu {
    display: block;
    position: absolute;
    top: 64px;
    left: 0;
    right: 0;
    background: #f4f4f4;
    padding: 20px 20px 26px;
    text-align: center;
    z-index: 30;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: opacity .25s ease, transform .25s ease, visibility .25s ease;
  }

  .eg-mobile-menu.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .eg-mobile-menu p {
    margin: 0 0 14px;
    font-size: 14px;
  }

  .eg-mobile-menu a {
    width: 244px;
    height: 48px;
    margin: 0 auto;
    background: #fff544;
    color: #000;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
    font-size: 15px;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var btn = document.getElementById('EgMenuToggle');
  var menu = document.getElementById('EgMobileMenu');

  if (btn && menu) {
    btn.addEventListener('click', function () {
      menu.classList.toggle('is-open');
      btn.textContent = menu.classList.contains('is-open') ? '×' : '☰';
    });
  }
});
</script>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    { "type": "image_picker", "id": "desktop_banner_image", "label": "Desktop banner image" },
    { "type": "image_picker", "id": "mobile_banner_image", "label": "Mobile banner image" },
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "TISSO VISON" },
    { "type": "text", "id": "top_text", "label": "Desktop top text", "default": "Find the ideal gift for your loved ones." },
    { "type": "text", "id": "top_button", "label": "Top button text", "default": "CHOOSE GIFT" },
    { "type": "url", "id": "button_link", "label": "Top button link" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Gift Guide" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Discover Joy: Your Ultimate Holiday Gift Destination." },
    { "type": "text", "id": "main_button", "label": "Main button text", "default": "SHOP NOW" },
    { "type": "url", "id": "main_button_link", "label": "Main button link" },
    { "type": "text", "id": "bottom_text", "label": "Bottom strip text", "default": "SUSTAINABLE, ETHICALLY MADE ACTIVEWEAR" },
    { "type": "text", "id": "mobile_menu_text", "label": "Mobile menu text", "default": "Find the ideal gift for your loved ones." }
  ],
  "presets": [{ "name": "Custom Banner" }]
}
{% endschema %}
