<section class="tisso-banner">
  <div class="tisso-banner__top">
    <div class="tisso-banner__logo">{{ section.settings.logo_text }}</div>
    <div class="tisso-banner__tagline">{{ section.settings.top_text }}</div>

    <a href="{{ section.settings.top_button_link | default: '#' }}" class="tisso-banner__choose">
      {{ section.settings.top_button }}
      <span>→</span>
    </a>
  </div>

  <div class="tisso-banner__content">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.description }}</p>

    <a href="{{ section.settings.main_button_link | default: '#' }}" class="tisso-banner__shop">
      {{ section.settings.main_button }}
      <span>→</span>
    </a>
  </div>

  <div class="tisso-banner__strip">
    {{ section.settings.bottom_text }}
  </div>
</section>

<style>
.tisso-banner {
  width: 100%;
  max-width: 1440px;
  height: 878px;
  margin: 0 auto;
  position: relative;
  overflow: hidden;
  font-family: Arial, Helvetica, sans-serif;
  color: #000;
  background-color: #fff;
  background-image: url({{ section.settings.desktop_banner | image_url: width: 1800 }});
  background-size: 100% auto;
  background-position: center top;
  background-repeat: no-repeat;
}

.tisso-banner__top {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 64px;
  display: grid;
  grid-template-columns: 1fr 1fr 214px;
  align-items: center;
  padding: 0 52px;
  box-sizing: border-box;
  background: transparent;
  z-index: 2;
}

.tisso-banner__logo {
  font-size: 18px;
  font-weight: 700;
}

.tisso-banner__tagline {
  text-align: center;
  font-size: 13px;
}

.tisso-banner__choose {
  height: 44px;
  background: #fff544;
  color: #000;
  text-decoration: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28px;
  font-size: 13px;
  font-weight: 500;
}

.tisso-banner__content {
  position: absolute;
  left: 64px;
  top: 382px;
  width: 440px;
  z-index: 2;
}

.tisso-banner__content h1 {
  margin: 0 0 30px;
  font-size: 56px;
  line-height: 1.02;
  font-weight: 700;
  letter-spacing: -1px;
}

.tisso-banner__content p {
  margin: 0;
  max-width: 390px;
  font-size: 15px;
  line-height: 1.45;
}

.tisso-banner__shop {
  margin-top: 34px;
  width: 210px;
  height: 52px;
  background: #000;
  color: #fff;
  text-decoration: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 38px;
  font-size: 13px;
}

.tisso-banner__strip {
  position: absolute;
  left: 0;
  right: 0;
  top: 844px;
  height: 34px;
  background: #f4f4f4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  text-align: center;
  z-index: 2;
}

@media screen and (max-width: 749px) {
  .tisso-banner {
    height: 445px;
    background-image: url({{ section.settings.mobile_banner | image_url: width: 900 }});
    background-size: 130% auto;
    background-position: center 150px;
    background-repeat: no-repeat;
    background-color: #fff;
  }

  .tisso-banner__top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 54px;
    display: grid;
    grid-template-columns: 26px 1fr;
    align-items: center;
    padding: 0 22px;
    background: #fff;
    z-index: 3;
  }

  .tisso-banner__top::before {
    content: "☰";
    font-size: 18px;
    color: #000;
  }

  .tisso-banner__logo {
    font-size: 20px;
    font-weight: 700;
    text-align: center;
    letter-spacing: 0.5px;
  }

  .tisso-banner__tagline,
  .tisso-banner__choose {
    display: none;
  }

  .tisso-banner__content {
    position: absolute;
    top: 92px;
    left: 20px;
    right: 20px;
    width: auto;
    text-align: center;
    z-index: 2;
  }

  .tisso-banner__content h1 {
    font-size: 24px;
    line-height: 1.1;
    font-weight: 700;
    margin: 0 0 14px;
  }

  .tisso-banner__content p {
    max-width: 245px;
    margin: 0 auto;
    font-size: 11px;
    line-height: 1.32;
  }

  .tisso-banner__shop {
    position: absolute;
    top: 337px;
    left: 50%;
    transform: translateX(-50%);
    width: 178px;
    height: 44px;
    margin: 0;
    background: #000;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 34px;
    font-size: 12px;
    text-decoration: none;
    z-index: 3;
  }

  .tisso-banner__strip {
    position: absolute;
    top: 421px;
    left: 0;
    right: 0;
    height: 24px;
    background: #f4f4f4;
    font-size: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
}
</style>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_banner",
      "label": "Desktop banner image"
    },
    {
      "type": "image_picker",
      "id": "mobile_banner",
      "label": "Mobile banner image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "top_text",
      "label": "Top center text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "top_button",
      "label": "Top button text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "top_button_link",
      "label": "Top button link"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "main_button",
      "label": "Main button text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "main_button_link",
      "label": "Main button link"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom strip text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}
