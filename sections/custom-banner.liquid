<div class="fixed-banner">

  <!-- DESKTOP -->
  <div class="banner-desktop">
    {% if section.settings.desktop_image %}
      <img src="{{ section.settings.desktop_image | image_url }}" alt="">
    {% endif %}

    <div class="banner-content">
      <h1>{{ section.settings.desktop_heading }}</h1>
      <p class="banner-subtext">{{ section.settings.desktop_subtext }}</p>

      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="banner-btn">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>

  <!-- MOBILE -->
  <div class="banner-mobile">
    {% if section.settings.mobile_image %}
      <img src="{{ section.settings.mobile_image | image_url }}" alt="">
    {% endif %}

    <div class="banner-content">
      <h1>{{ section.settings.mobile_heading }}</h1>
      <p class="banner-subtext">{{ section.settings.mobile_subtext }}</p>

      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="banner-btn">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>

</div>

<style>
.fixed-banner img {
  width: 100%;
  display: block;
}

.banner-content {
  text-align: center;
  padding: 20px;
}

.banner-subtext {
  white-space: pre-line;
}

.banner-btn {
  display: inline-block;
  margin-top: 15px;
  padding: 10px 24px;
  background: #000;
  color: #fff;
  text-decoration: none;
}

/* RESPONSIVE CONTROL */
.banner-desktop { display: block; }
.banner-mobile { display: none; }

@media (max-width: 768px) {
  .banner-desktop { display: none; }
  .banner-mobile { display: block; }
}
</style>

{% schema %}
{
  "name": "Fixed Banner (Desktop + Mobile)",
  "settings": [
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop Image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile Image" },

    { "type": "text", "id": "desktop_heading", "label": "Desktop Heading" },
    { "type": "textarea", "id": "desktop_subtext", "label": "Desktop Sub Text" },

    { "type": "text", "id": "mobile_heading", "label": "Mobile Heading" },
    { "type": "textarea", "id": "mobile_subtext", "label": "Mobile Sub Text" },

    { "type": "text", "id": "button_text", "label": "Button Text" },
    { "type": "url", "id": "button_link", "label": "Button Link" }
  ],
  "presets": [
    { "name": "Fixed Banner Final" }
  ]
}
{% endschema %}
