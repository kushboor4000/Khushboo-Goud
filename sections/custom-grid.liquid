<section class="eg-grid">
  <h2>{{ section.settings.heading }}</h2>

  <div class="eg-grid__items">
    {% for block in section.blocks %}
      {% assign product = block.settings.product %}
      {% if product != blank %}
        <div class="eg-grid__card" {{ block.shopify_attributes }}>
          <img
            src="{{ product.featured_image | image_url: width: 900 }}"
            alt="{{ product.title | escape }}"
            width="900"
            height="1100"
            loading="lazy"
          >

          <button
            type="button"
            class="eg-grid__plus"
            data-title="{{ product.title | escape }}"
            data-price="{{ product.price | money }}"
            data-desc="{{ product.description | strip_html | escape }}"
            data-image="{{ product.featured_image | image_url: width: 300 }}"
            data-variants='{{ product.variants | json | escape }}'
            data-options='{{ product.options_with_values | json | escape }}'
            aria-label="Open {{ product.title | escape }}"
          >
            +
          </button>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="eg-popup" id="EgPopup">
    <div class="eg-popup__overlay" data-close></div>

    <div class="eg-popup__box">
      <button type="button" class="eg-popup__close" data-close>×</button>

      <div class="eg-popup__top">
        <img id="EgImage" src="" alt="" width="120" height="140">

        <div class="eg-popup__info">
          <h3 id="EgTitle"></h3>
          <p id="EgPrice"></p>
          <div id="EgDesc"></div>
        </div>
      </div>

      <div class="eg-option">
        <label>Color</label>
        <div class="eg-color-boxes" id="EgColorOptions"></div>
      </div>

      <div class="eg-option">
        <label>Size</label>

        <div class="eg-size-dropdown" id="EgSizeDropdown">
          <button type="button" class="eg-size-trigger" id="EgSizeTrigger">
            <span id="EgSizeText">Choose your size</span>
            <span class="eg-size-arrow"></span>
          </button>

          <div class="eg-size-menu" id="EgSizeMenu"></div>
        </div>
      </div>

      <button type="button" id="EgCartBtn" class="eg-popup__cart">
        ADD TO CART
      </button>

      <p id="EgMessage"></p>
    </div>
  </div>
</section>

<style>
@import url('https://fonts.googleapis.com/css2?family=Lustria&display=swap');

.eg-grid,
.eg-grid * {
  font-family: 'Lustria', serif;
}

.eg-grid {
  max-width: 1440px;
  margin: 0 auto;
  padding: 36px 67px 60px;
  background: #fff;
  box-shadow: 0 0 0 100vw #000;
  clip-path: inset(0 -100vw);
}

.eg-grid h2 {
  margin: 0 0 28px;
  padding-left: 0;
  font-size: 28px;
  font-weight: 400;
  text-align: left;
}

.eg-grid__items {
  width: 100%;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.eg-grid__card {
  position: relative;
  background: #f4f4f4;
  overflow: hidden;
}

.eg-grid__card img {
  width: 100%;
  height: 500px;
  object-fit: cover;
  display: block;
}

.eg-grid__plus {
  position: absolute;
  transform: translate(-50%, -50%);
  width: 22px;
  height: 22px;
  border: 0;
  border-radius: 50%;
  background: #fff;
  color: #000;
  font-size: 18px;
  line-height: 19px;
  cursor: pointer;
  padding: 0;
  z-index: 3;
}

.eg-grid__card:nth-child(1) .eg-grid__plus { top: 63%; left: 54%; }
.eg-grid__card:nth-child(2) .eg-grid__plus { top: 53%; left: 84%; }
.eg-grid__card:nth-child(3) .eg-grid__plus { top: 21%; left: 64%; }
.eg-grid__card:nth-child(4) .eg-grid__plus { top: 16%; left: 73%; }
.eg-grid__card:nth-child(5) .eg-grid__plus { top: 22%; left: 52%; }
.eg-grid__card:nth-child(6) .eg-grid__plus { top: 67%; left: 45%; }

.eg-popup {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 99999;
  align-items: center;
  justify-content: center;
}

.eg-popup.is-open {
  display: flex;
}

.eg-popup__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.eg-popup__box {
  position: relative;
  z-index: 2;
  width: 311px;
  height: 447px;
  padding: 20px 17px 0;
  background: #fff;
  border: 1px solid #000;
  box-sizing: border-box;
  overflow: visible;
}

.eg-popup__close {
  position: absolute;
  top: 9px;
  right: 14px;
  background: transparent;
  border: 0;
  color: #000;
  font-size: 26px;
  line-height: 1;
  cursor: pointer;
  padding: 0;
}

.eg-popup__top {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 9px;
  align-items: start;
}

.eg-popup__top img {
  width: 120px;
  height: 140px;
  object-fit: cover;
  display: block;
}

.eg-popup__info {
  padding-top: 3px;
}

.eg-popup h3 {
  margin: 0 20px 11px 0;
  font-size: 16px;
  line-height: 1.22;
  font-weight: 400;
  color: #000;
}

#EgPrice {
  margin: 0 0 13px;
  font-size: 16px;
  line-height: 1.2;
  color: #000;
}

#EgDesc {
  height: 54px;
  overflow: hidden;
  font-size: 12px;
  line-height: 1.12;
  color: #000;
}

.eg-option {
  margin-top: 12px;
}

.eg-option label {
  display: block;
  margin-bottom: 6px;
  color: #000;
  font-size: 13px;
  font-weight: 400;
  line-height: 1;
}

.eg-color-boxes {
  position: relative;
  display: grid;
  grid-template-columns: 1fr 1fr;
  height: 41px;
  border: 1px solid #777;
}

.eg-color-boxes::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 5px;
  background: #1f5fbf;
  z-index: 3;
}

.eg-color-btn {
  position: relative;
  border: 0;
  border-right: 1px solid #777;
  background: #fff;
  color: #000;
  padding: 0 11px;
  text-align: left;
  font-size: 16px;
  cursor: pointer;
}

.eg-color-btn:last-child {
  border-right: 0;
}

.eg-color-btn:hover {
  background: #fff;
  color: #000;
}

.eg-color-btn.is-selected {
  background: #000;
  color: #fff;
}

.eg-color-btn.is-selected::before {
  display: none;
}

.eg-size-dropdown {
  position: relative;
  width: 100%;
}

.eg-size-trigger {
  width: 100%;
  height: 41px;
  border: 1px solid #777;
  background: #fff;
  color: #000;
  padding: 0;
  display: grid;
  grid-template-columns: 1fr 68px;
  align-items: center;
  cursor: pointer;
  font-size: 16px;
}

.eg-size-trigger span:first-child {
  text-align: left;
  padding-left: 15px;
}

.eg-size-arrow {
  width: 100%;
  height: 100%;
  border-left: 1px solid #777;
  position: relative;
}

.eg-size-arrow::after {
  content: "";
  position: absolute;
  top: 12px;
  left: 27px;
  width: 10px;
  height: 10px;
  border-left: 2px solid #000;
  border-top: 2px solid #000;
  transform: rotate(225deg);
}

.eg-size-dropdown.is-open .eg-size-arrow::after {
  top: 16px;
  transform: rotate(45deg);
}

.eg-size-menu {
  display: none;
  width: 100%;
  border-left: 1px solid #777;
  border-right: 1px solid #777;
  border-bottom: 1px solid #777;
  background: #fff;
  box-sizing: border-box;
  position: absolute;
  left: 0;
  top: 41px;
  z-index: 20;
}

.eg-size-dropdown.is-open .eg-size-menu {
  display: block;
}

.eg-size-menu button {
  width: 100%;
  height: 39px;
  border: 0;
  background: #fff;
  color: #000;
  font-size: 16px;
  text-align: center;
  cursor: pointer;
}

.eg-size-menu button:hover,
.eg-size-menu button.is-selected {
  background: #000;
  color: #fff;
}

.eg-popup__cart {
  width: 100%;
  height: 45px;
  margin-top: 49px;
  background: #000;
  color: #fff;
  border: 0;
  font-size: 14px;
  font-weight: 400;
  cursor: pointer;
  letter-spacing: 0.2px;
}

.eg-popup__cart::after {
  content: " →";
  font-size: 29px;
  margin-left: 28px;
  vertical-align: -4px;
}

#EgMessage {
  margin: 6px 0 0;
  font-size: 11px;
  line-height: 1.2;
  color: #000;
}

@media (max-width: 749px) {
  .eg-grid {
    margin: 0 auto;
    padding: 0 0 38px;
    background: #fff;
    box-shadow: none;
    clip-path: none;
  }

  .eg-grid h2 {
    max-width: none;
    margin: 0 0 28px;
    padding: 10px 16px 0;
    font-size: 26px;
    text-align: left;
  }

  .eg-grid__items {
    max-width: none;
    margin: 0;
    grid-template-columns: repeat(2, 1fr);
    gap: 3px;
  }

  .eg-grid__card img {
    height: 230px;
  }

  .eg-grid__plus {
    width: 20px;
    height: 20px;
    font-size: 16px;
    line-height: 18px;
  }

  .eg-grid__card:nth-child(1) .eg-grid__plus { top: 62%; left: 55%; }
  .eg-grid__card:nth-child(2) .eg-grid__plus { top: 52%; left: 84%; }
  .eg-grid__card:nth-child(3) .eg-grid__plus { top: 20%; left: 65%; }
  .eg-grid__card:nth-child(4) .eg-grid__plus { top: 16%; left: 73%; }
  .eg-grid__card:nth-child(5) .eg-grid__plus { top: 22%; left: 52%; }
  .eg-grid__card:nth-child(6) .eg-grid__plus { top: 67%; left: 45%; }

  .eg-popup__box {
    width: 311px;
    height: 447px;
  }
}
</style>

<script>
(function () {
  const popup = document.getElementById('EgPopup');
  const image = document.getElementById('EgImage');
  const title = document.getElementById('EgTitle');
  const price = document.getElementById('EgPrice');
  const desc = document.getElementById('EgDesc');
  const colorOptions = document.getElementById('EgColorOptions');
  const sizeDropdown = document.getElementById('EgSizeDropdown');
  const sizeTrigger = document.getElementById('EgSizeTrigger');
  const sizeText = document.getElementById('EgSizeText');
  const sizeMenu = document.getElementById('EgSizeMenu');
  const cartBtn = document.getElementById('EgCartBtn');
  const message = document.getElementById('EgMessage');

  const softWinterJacketVariantId = {{ section.settings.soft_winter_jacket.selected_or_first_available_variant.id | default: 'null' }};

  let currentVariants = [];
  let currentOptions = [];
  let selectedColor = '';
  let selectedSize = '';

  function openPopup() {
    popup.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closePopup() {
    popup.classList.remove('is-open');
    document.body.style.overflow = '';
    message.textContent = '';
    sizeDropdown.classList.remove('is-open');
  }

  function getOptionName(option) {
    return typeof option === 'string' ? option : option.name;
  }

  function getOptionValues(option) {
    if (!option) return [];
    if (Array.isArray(option.values)) return option.values;
    return [];
  }

  function getColorOption() {
    return currentOptions.find(function (option) {
      return getOptionName(option).toLowerCase().includes('color');
    });
  }

  function getSizeOption() {
    return currentOptions.find(function (option) {
      const name = getOptionName(option).toLowerCase();
      return name.includes('size') || name.includes('option');
    });
  }

  function getColorValues() {
    const colorOption = getColorOption();

    if (colorOption && getOptionValues(colorOption).length) {
      return getOptionValues(colorOption);
    }

    const values = [];

    currentVariants.forEach(function (variant) {
      (variant.options || []).forEach(function (value) {
        if (!values.includes(value) && ['black', 'white', 'blue', 'red', 'green', 'grey', 'gray', 'brown'].includes(String(value).toLowerCase())) {
          values.push(value);
        }
      });
    });

    return values.length ? values : ['White', 'Black'];
  }

  function getSizeValues() {
    const sizeOption = getSizeOption();

    if (sizeOption && getOptionValues(sizeOption).length) {
      return getOptionValues(sizeOption);
    }

    const sizeOrder = ['XS', 'S', 'M', 'Medium', 'L', 'XL'];
    const values = [];

    currentVariants.forEach(function (variant) {
      (variant.options || []).forEach(function (value) {
        if (!values.includes(value) && sizeOrder.map(function (v) { return v.toLowerCase(); }).includes(String(value).toLowerCase())) {
          values.push(value);
        }
      });
    });

    return values.length ? values : ['XS', 'S', 'M', 'L', 'XL'];
  }

  function normalize(value) {
    return String(value || '').trim().toLowerCase();
  }

  function isMedium(value) {
    return normalize(value) === 'medium' || normalize(value) === 'm';
  }

  function findVariant() {
    if (!currentVariants.length) return null;

    return currentVariants.find(function (variant) {
      const opts = variant.options || [];
      const colorMatch = !selectedColor || opts.some(function (opt) {
        return normalize(opt) === normalize(selectedColor);
      });

      const sizeMatch = !selectedSize || opts.some(function (opt) {
        return normalize(opt) === normalize(selectedSize);
      });

      return colorMatch && sizeMatch;
    }) || null;
  }

  function updatePriceFromVariant() {
    const variant = findVariant();

    if (variant && typeof variant.price !== 'undefined') {
      price.textContent = Shopify.formatMoney
        ? Shopify.formatMoney(variant.price, {{ shop.money_format | json }})
        : price.textContent;
    }
  }

  function renderColors() {
    const colors = getColorValues();
    colorOptions.innerHTML = '';
    selectedColor = colors[0] || '';

    colors.forEach(function (color, index) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'eg-color-btn';
      btn.textContent = color;

      if (index === 0) btn.classList.add('is-selected');

      btn.addEventListener('click', function () {
        selectedColor = color;

        colorOptions.querySelectorAll('.eg-color-btn').forEach(function (item) {
          item.classList.remove('is-selected');
        });

        btn.classList.add('is-selected');
        updatePriceFromVariant();
      });

      colorOptions.appendChild(btn);
    });
  }

  function renderSizes() {
    const sizes = getSizeValues();
    sizeMenu.innerHTML = '';

    sizes.forEach(function (size) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.dataset.size = size;
      btn.textContent = size;

      btn.addEventListener('click', function (event) {
        event.stopPropagation();

        selectedSize = size;
        sizeText.textContent = selectedSize;

        sizeMenu.querySelectorAll('button').forEach(function (item) {
          item.classList.remove('is-selected');
        });

        btn.classList.add('is-selected');
        sizeDropdown.classList.remove('is-open');
        updatePriceFromVariant();
      });

      sizeMenu.appendChild(btn);
    });
  }

  function resetSize() {
    selectedSize = '';
    sizeText.textContent = 'Choose your size';
    sizeDropdown.classList.remove('is-open');
    sizeMenu.innerHTML = '';
  }

  function loadPopup(btn) {
    title.textContent = btn.dataset.title || '';
    price.textContent = btn.dataset.price || '';
    desc.textContent = btn.dataset.desc || '';
    image.src = btn.dataset.image || '';
    image.alt = btn.dataset.title || '';
    message.textContent = '';

    try {
      currentVariants = JSON.parse(btn.dataset.variants || '[]');
      currentOptions = JSON.parse(btn.dataset.options || '[]');
    } catch (error) {
      currentVariants = [];
      currentOptions = [];
    }

    resetSize();
    renderColors();
    renderSizes();
    openPopup();
  }

  async function addItemsToCart(items) {
    const root = window.Shopify && window.Shopify.routes && window.Shopify.routes.root
      ? window.Shopify.routes.root
      : '/';

    const response = await fetch(root + 'cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({ items: items })
    });

    if (!response.ok) {
      throw new Error('Cart add failed');
    }

    return response.json();
  }

  async function getCart() {
    const root = window.Shopify && window.Shopify.routes && window.Shopify.routes.root
      ? window.Shopify.routes.root
      : '/';

    const response = await fetch(root + 'cart.js', {
      headers: { 'Accept': 'application/json' }
    });

    return response.json();
  }

  function updateCartCount(cart) {
    const cartIcon = document.querySelector('#cart-icon-bubble');
    if (!cartIcon) return;

    let bubble = cartIcon.querySelector('.cart-count-bubble');

    if (!bubble) {
      bubble = document.createElement('div');
      bubble.className = 'cart-count-bubble';
      bubble.innerHTML = '<span aria-hidden="true"></span><span class="visually-hidden"></span>';
      cartIcon.appendChild(bubble);
    }

    const visibleCount = bubble.querySelector('span[aria-hidden="true"]');
    const hiddenCount = bubble.querySelector('.visually-hidden');

    if (visibleCount) visibleCount.textContent = cart.item_count;
    if (hiddenCount) hiddenCount.textContent = cart.item_count + ' items';
  }

  function shouldAddSoftWinterJacket() {
    return normalize(selectedColor) === 'black' && isMedium(selectedSize) && softWinterJacketVariantId;
  }

  document.querySelectorAll('.eg-grid__plus').forEach(function (btn) {
    btn.addEventListener('click', function () {
      loadPopup(btn);
    });
  });

  sizeTrigger.addEventListener('click', function (event) {
    event.stopPropagation();
    sizeDropdown.classList.toggle('is-open');
  });

  document.addEventListener('click', function (event) {
    if (!sizeDropdown.contains(event.target)) {
      sizeDropdown.classList.remove('is-open');
    }
  });

  document.querySelectorAll('[data-close]').forEach(function (btn) {
    btn.addEventListener('click', closePopup);
  });

  document.addEventListener('keydown', function (event) {
    if (event.key === 'Escape') closePopup();
  });

  cartBtn.addEventListener('click', async function () {
    if (!selectedSize) {
      message.textContent = 'Please choose your size.';
      return;
    }

    const variant = findVariant();

    if (!variant || !variant.id) {
      message.textContent = 'Selected variant is not available.';
      return;
    }

    const items = [
      {
        id: variant.id,
        quantity: 1
      }
    ];

    const addJacket = shouldAddSoftWinterJacket();

    if (addJacket) {
      items.push({
        id: softWinterJacketVariantId,
        quantity: 1
      });
    }

    cartBtn.disabled = true;
    cartBtn.textContent = 'ADDING';
    message.textContent = 'Adding...';

    try {
      await addItemsToCart(items);

      const cart = await getCart();
      updateCartCount(cart);

      message.textContent = addJacket
        ? 'Added to cart with Soft Winter Jacket.'
        : 'Added to cart.';

      cartBtn.textContent = 'ADDED';

      setTimeout(function () {
        cartBtn.disabled = false;
        cartBtn.textContent = 'ADD TO CART';
      }, 1500);
    } catch (error) {
      message.textContent = 'Could not add to cart.';
      cartBtn.disabled = false;
      cartBtn.textContent = 'ADD TO CART';
      console.error(error);
    }
  });
})();
</script>

{% schema %}
{
  "name": "Custom Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "product",
      "id": "soft_winter_jacket",
      "label": "Soft Winter Jacket product"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Choose product"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom Grid"
    }
  ]
}
{% endschema %}
