<section class="eg-grid">
  <h2>{{ section.settings.heading }}</h2>

  <div class="eg-grid__items">
    {% for block in section.blocks %}
      {% assign product = block.settings.product %}
      {% if product != blank %}
        <div
          class="eg-grid__card"
          {{ block.shopify_attributes }}
          style="
            --plus-x: {{ block.settings.plus_x }}%;
            --plus-y: {{ block.settings.plus_y }}%;
            --plus-x-mobile: {{ block.settings.plus_x_mobile }}%;
            --plus-y-mobile: {{ block.settings.plus_y_mobile }}%;
          "
        >
          <img
            src="{{ product.featured_image | image_url: width: 900 }}"
            alt="{{ product.title | escape }}"
            width="900"
            height="1100"
            loading="lazy"
          >

          <button
            type="button"
            class="eg-grid__plus"
            data-product='{{ product | json | escape }}'
            aria-label="Open {{ product.title | escape }}"
          >
            +
          </button>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="eg-popup" id="EgPopup">
    <div class="eg-popup__overlay" data-close></div>

    <div class="eg-popup__box">
      <button type="button" class="eg-popup__close" data-close>×</button>

      <div class="eg-popup__top">
        <img id="EgImage" src="" alt="" width="120" height="140">

        <div class="eg-popup__info">
          <h3 id="EgTitle"></h3>
          <p id="EgPrice"></p>
          <div id="EgDesc"></div>
        </div>
      </div>

      <div class="eg-option eg-color-option" id="EgColorWrap">
        <label>Color</label>
        <div class="eg-color-boxes" id="EgColorOptions"></div>
      </div>

      <div class="eg-option eg-size-option" id="EgSizeWrap">
        <label>Size</label>
        <div class="eg-size-select-wrap">
          <select id="EgSizeSelect">
            <option value="">Choose your size</option>
          </select>
        </div>
      </div>

      <button type="button" id="EgCartBtn" class="eg-popup__cart">
        ADD TO CART
      </button>

      <p id="EgMessage"></p>
    </div>
  </div>
</section>

<style>
.eg-grid {
  max-width: 1440px;
  margin: 0 auto;
  padding: 55px 50px;
  font-family: Arial, sans-serif;
}

.eg-grid h2 {
  font-size: 32px;
  margin: 0 0 28px;
  font-weight: 500;
  text-align: center;
}

.eg-grid__items {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.eg-grid__card {
  position: relative;
  background: #f4f4f4;
  overflow: hidden;
}

.eg-grid__card img {
  width: 100%;
  height: 430px;
  object-fit: cover;
  display: block;
}

.eg-grid__plus {
  position: absolute;
  top: var(--plus-y);
  left: var(--plus-x);
  transform: translate(-50%, -50%);
  width: 22px;
  height: 22px;
  border: 0;
  border-radius: 50%;
  background: #fff;
  color: #000;
  font-size: 18px;
  line-height: 19px;
  cursor: pointer;
  padding: 0;
  z-index: 3;
}

.eg-popup {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 99999;
}

.eg-popup.is-open {
  display: block;
}

.eg-popup__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.eg-popup__box {
  position: relative;
  z-index: 2;
  width: 311px;
  height: 447px;
  margin: 35px auto;
  padding: 20px 18px 0;
  background: #fff;
  border: 1px solid #000;
  box-sizing: border-box;
  font-family: Arial, sans-serif;
  overflow: hidden;
}

.eg-popup__close {
  position: absolute;
  top: 10px;
  right: 15px;
  background: transparent;
  border: 0;
  color: #000;
  font-size: 27px;
  line-height: 1;
  cursor: pointer;
  padding: 0;
}

.eg-popup__top {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 9px;
  align-items: start;
}

.eg-popup__top img {
  width: 120px;
  height: 140px;
  object-fit: cover;
  display: block;
}

.eg-popup__info {
  padding-top: 3px;
}

.eg-popup h3 {
  margin: 0 22px 11px 0;
  font-size: 16px;
  line-height: 1.22;
  font-weight: 400;
  color: #000;
}

#EgPrice {
  margin: 0 0 13px;
  font-size: 16px;
  line-height: 1.2;
  color: #000;
}

#EgDesc {
  font-size: 12px;
  line-height: 1.12;
  color: #000;
  height: 54px;
  overflow: hidden;
}

.eg-option {
  margin-top: 12px;
}

.eg-option label {
  display: block;
  margin-bottom: 6px;
  color: #000;
  font-size: 13px;
  font-weight: 400;
  line-height: 1;
}

.eg-color-boxes {
  display: grid;
  grid-template-columns: 1fr 1fr;
  height: 41px;
  border: 1px solid #777;
}

.eg-color-btn {
  position: relative;
  border: 0;
  border-right: 1px solid #777;
  background: #fff;
  color: #000;
  padding: 0 11px;
  text-align: left;
  font-size: 16px;
  cursor: pointer;
}

.eg-color-btn:last-child {
  border-right: 0;
}

.eg-color-btn.is-selected::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 5px;
  background: var(--swatch-color, #000);
}

.eg-size-select-wrap {
  position: relative;
  height: 41px;
  border: 1px solid #777;
}

.eg-size-select-wrap::after {
  content: "";
  position: absolute;
  right: 17px;
  top: 14px;
  width: 10px;
  height: 10px;
  border-right: 1.5px solid #000;
  border-bottom: 1.5px solid #000;
  transform: rotate(45deg);
  pointer-events: none;
}

.eg-size-select-wrap::before {
  content: "";
  position: absolute;
  top: 0;
  right: 53px;
  width: 1px;
  height: 100%;
  background: #777;
  pointer-events: none;
}

#EgSizeSelect {
  width: 100%;
  height: 100%;
  border: 0;
  background: #fff;
  color: #000;
  padding: 0 58px 0 11px;
  font-size: 15px;
  appearance: none;
  cursor: pointer;
}

.eg-popup__cart {
  width: 100%;
  height: 45px;
  margin-top: 49px;
  background: #000;
  color: #fff;
  border: 0;
  font-size: 14px;
  font-weight: 400;
  cursor: pointer;
  letter-spacing: 0.2px;
}

.eg-popup__cart::after {
  content: " →";
  font-size: 29px;
  margin-left: 28px;
  vertical-align: -4px;
}

#EgMessage {
  margin: 6px 0 0;
  font-size: 11px;
  line-height: 1.2;
  color: #000;
}

@media (max-width: 749px) {
  .eg-grid {
    padding: 38px 0;
  }

  .eg-grid h2 {
    font-size: 26px;
    padding: 0 16px;
  }

  .eg-grid__items {
    grid-template-columns: repeat(2, 1fr);
    gap: 3px;
  }

  .eg-grid__card img {
    height: 230px;
  }

  .eg-grid__plus {
    top: var(--plus-y-mobile);
    left: var(--plus-x-mobile);
    width: 20px;
    height: 20px;
    font-size: 16px;
    line-height: 18px;
  }

  .eg-popup__box {
    width: 311px;
    height: 447px;
    margin: 4px auto;
  }
}
</style>

<script>
(function () {
  const popup = document.getElementById('EgPopup');
  const image = document.getElementById('EgImage');
  const title = document.getElementById('EgTitle');
  const price = document.getElementById('EgPrice');
  const desc = document.getElementById('EgDesc');
  const colorWrap = document.getElementById('EgColorWrap');
  const colorOptions = document.getElementById('EgColorOptions');
  const sizeWrap = document.getElementById('EgSizeWrap');
  const sizeSelect = document.getElementById('EgSizeSelect');
  const cartBtn = document.getElementById('EgCartBtn');
  const message = document.getElementById('EgMessage');

  let currentProduct = null;
  let selectedOptions = [];

  function money(cents) {
    return (cents / 100).toLocaleString('en-US', {
      style: 'currency',
      currency: '{{ cart.currency.iso_code }}'
    });
  }

  function getImage(product) {
    if (product.featured_image) return product.featured_image;
    if (product.images && product.images.length) return product.images[0];
    return '';
  }

  function cleanDescription(html) {
    const div = document.createElement('div');
    div.innerHTML = html || '';
    return div.textContent || div.innerText || '';
  }

  function colorValue(colorName) {
    const colors = {
      black: '#000',
      white: '#fff',
      blue: '#1f5fbf',
      red: '#b00028',
      grey: '#b8b8b8',
      gray: '#b8b8b8',
      green: '#2f6b4f',
      yellow: '#f2c94c',
      pink: '#f2a3b3',
      brown: '#7a4a28'
    };

    return colors[String(colorName).toLowerCase()] || '#000';
  }

  function openPopup() {
    popup.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closePopup() {
    popup.classList.remove('is-open');
    document.body.style.overflow = '';
    message.textContent = '';
  }

  function findOptionIndex(name) {
    if (!currentProduct || !currentProduct.options) return -1;

    return currentProduct.options.findIndex(function (option) {
      const optionName = typeof option === 'string' ? option : option.name;
      return optionName && optionName.toLowerCase().includes(name);
    });
  }

  function uniqueValues(optionIndex) {
    const values = [];

    currentProduct.variants.forEach(function (variant) {
      const value = variant.options[optionIndex];
      if (value && !values.includes(value)) {
        values.push(value);
      }
    });

    return values;
  }

  function selectedVariant() {
    if (!currentProduct) return null;

    return currentProduct.variants.find(function (variant) {
      return variant.options.every(function (value, index) {
        return selectedOptions[index] === value;
      });
    });
  }

  function updatePrice() {
    const variant = selectedVariant() || currentProduct.variants[0];

    if (variant) {
      price.textContent = money(variant.price);
    }
  }

  function renderColorOptions() {
    const colorIndex = findOptionIndex('color');

    colorOptions.innerHTML = '';

    if (colorIndex === -1) {
      colorWrap.style.display = 'none';
      return;
    }

    colorWrap.style.display = 'block';

    const values = uniqueValues(colorIndex).slice(0, 2);

    values.forEach(function (value, index) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'eg-color-btn';
      btn.textContent = value;
      btn.style.setProperty('--swatch-color', colorValue(value));

      if (index === 0) {
        btn.classList.add('is-selected');
        selectedOptions[colorIndex] = value;
      }

      btn.addEventListener('click', function () {
        selectedOptions[colorIndex] = value;

        colorOptions.querySelectorAll('.eg-color-btn').forEach(function (item) {
          item.classList.remove('is-selected');
        });

        btn.classList.add('is-selected');
        updatePrice();
      });

      colorOptions.appendChild(btn);
    });
  }

  function renderSizeOptions() {
    const sizeIndex = findOptionIndex('size');

    sizeSelect.innerHTML = '<option value="">Choose your size</option>';

    if (sizeIndex === -1) {
      sizeWrap.style.display = 'none';
      return;
    }

    sizeWrap.style.display = 'block';
    selectedOptions[sizeIndex] = '';

    uniqueValues(sizeIndex).forEach(function (value) {
      const option = document.createElement('option');
      option.value = value;
      option.textContent = value;
      sizeSelect.appendChild(option);
    });

    sizeSelect.onchange = function () {
      selectedOptions[sizeIndex] = sizeSelect.value;
      updatePrice();
    };
  }

  function loadProduct(productData) {
    currentProduct = productData;
    selectedOptions = currentProduct.variants[0].options.slice();

    image.src = getImage(currentProduct);
    image.alt = currentProduct.title || '';
    title.textContent = currentProduct.title || '';
    desc.textContent = cleanDescription(currentProduct.description);
    message.textContent = '';

    renderColorOptions();
    renderSizeOptions();
    updatePrice();
    openPopup();
  }

  document.querySelectorAll('.eg-grid__plus').forEach(function (btn) {
    btn.addEventListener('click', function () {
      try {
        const productData = JSON.parse(btn.dataset.product);
        loadProduct(productData);
      } catch (error) {
        message.textContent = 'Product could not be loaded.';
        openPopup();
      }
    });
  });

  document.querySelectorAll('[data-close]').forEach(function (btn) {
    btn.addEventListener('click', closePopup);
  });

  document.addEventListener('keydown', function (event) {
    if (event.key === 'Escape') closePopup();
  });

  cartBtn.addEventListener('click', async function () {
    const sizeIndex = findOptionIndex('size');

    if (sizeIndex !== -1 && !selectedOptions[sizeIndex]) {
      message.textContent = 'Please choose your size.';
      return;
    }

    const variant = selectedVariant();

    if (!variant) {
      message.textContent = 'Please select available options.';
      return;
    }

    message.textContent = 'Adding...';

    try {
      const root = window.Shopify && window.Shopify.routes && window.Shopify.routes.root
        ? window.Shopify.routes.root
        : '/';

      await fetch(root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: variant.id,
          quantity: 1
        })
      });

      message.textContent = 'Added to cart.';
    } catch (error) {
      message.textContent = 'Could not add to cart.';
    }
  });
})();
</script>

{% schema %}
{
  "name": "Custom Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Choose product"
        },
        {
          "type": "range",
          "id": "plus_x",
          "label": "Plus icon horizontal position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 55
        },
        {
          "type": "range",
          "id": "plus_y",
          "label": "Plus icon vertical position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 55
        },
        {
          "type": "range",
          "id": "plus_x_mobile",
          "label": "Mobile plus icon horizontal position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 55
        },
        {
          "type": "range",
          "id": "plus_y_mobile",
          "label": "Mobile plus icon vertical position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 55
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom Grid"
    }
  ]
}
{% endschema %}
