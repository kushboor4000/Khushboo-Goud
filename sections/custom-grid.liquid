<section class="eg-grid">
  <div class="eg-grid__header">
    <h2>{{ section.settings.heading }}</h2>
  </div>

  <div class="eg-grid__items">
    {% for block in section.blocks %}
      {% assign product = block.settings.product %}

      {% if product != blank %}
        <div class="eg-grid__card" {{ block.shopify_attributes }}>
          <div class="eg-grid__image-wrap">
            <img
              src="{{ product.featured_image | image_url: width: 700 }}"
              alt="{{ product.title | escape }}"
              width="700"
              height="900"
              loading="lazy"
            >

            <button
              type="button"
              class="eg-grid__plus"
              data-product-handle="{{ product.handle }}"
              aria-label="Open {{ product.title | escape }}"
            >
              +
            </button>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="eg-popup" id="EgProductPopup" aria-hidden="true">
    <div class="eg-popup__overlay" data-close-popup></div>

    <div class="eg-popup__box">
      <button type="button" class="eg-popup__close" data-close-popup>×</button>

      <div class="eg-popup__content">
        <div class="eg-popup__image">
          <img id="EgPopupImage" src="" alt="" width="400" height="500">
        </div>

        <div class="eg-popup__info">
          <h3 id="EgPopupTitle"></h3>
          <p id="EgPopupPrice"></p>
          <div id="EgPopupDescription" class="eg-popup__description"></div>

          <div id="EgPopupOptions" class="eg-popup__options"></div>

          <button type="button" id="EgAddToCart" class="eg-popup__cart">
            ADD TO CART
          </button>

          <p id="EgPopupMessage" class="eg-popup__message"></p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .eg-grid {
    max-width: 1100px;
    margin: 0 auto;
    padding: 55px 20px;
    font-family: Arial, sans-serif;
  }

  .eg-grid__header h2 {
    margin: 0 0 24px;
    font-size: 28px;
    font-weight: 500;
    color: #000;
  }

  .eg-grid__items {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .eg-grid__image-wrap {
    position: relative;
    background: #f4f4f4;
    overflow: hidden;
  }

  .eg-grid__image-wrap img {
    width: 100%;
    height: 360px;
    object-fit: cover;
    display: block;
  }

  .eg-grid__plus {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 24px;
    height: 24px;
    border: none;
    border-radius: 50%;
    background: #fff8d9;
    color: #000;
    font-size: 20px;
    line-height: 20px;
    cursor: pointer;
    transform: translate(-50%, -50%);
    transition: transform 0.25s ease, background 0.25s ease;
  }

  .eg-grid__plus:hover {
    transform: translate(-50%, -50%) scale(1.15);
    background: #fff200;
  }

  .eg-popup {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
  }

  .eg-popup.is-open {
    display: block;
  }

  .eg-popup__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
  }

  .eg-popup__box {
    position: relative;
    z-index: 2;
    max-width: 650px;
    background: #fff;
    margin: 80px auto;
    padding: 20px;
  }

  .eg-popup__close {
    position: absolute;
    top: 8px;
    right: 12px;
    border: 0;
    background: transparent;
    font-size: 30px;
    cursor: pointer;
  }

  .eg-popup__content {
    display: grid;
    grid-template-columns: 42% 1fr;
    gap: 20px;
  }

  .eg-popup__image img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    display: block;
    background: #f4f4f4;
  }

  .eg-popup__info h3 {
    margin: 0 0 8px;
    font-size: 18px;
    color: #000;
  }

  .eg-popup__info p {
    margin: 0 0 12px;
    color: #000;
  }

  .eg-popup__description {
    font-size: 13px;
    line-height: 1.4;
    margin-bottom: 14px;
    color: #333;
  }

  .eg-option {
    margin-bottom: 14px;
  }

  .eg-option label {
    display: block;
    font-size: 13px;
    margin-bottom: 8px;
    font-weight: 700;
  }

  .eg-option__values {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .eg-option__btn {
    border: 1px solid #000;
    background: #fff;
    color: #000;
    padding: 8px 12px;
    cursor: pointer;
    font-size: 12px;
  }

  .eg-option__btn.is-selected {
    background: #000;
    color: #fff;
  }

  .eg-popup__cart {
    width: 100%;
    border: 0;
    background: #000;
    color: #fff;
    padding: 14px;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.25s ease;
  }

  .eg-popup__cart:hover {
    transform: translateY(-2px);
  }

  .eg-popup__message {
    margin-top: 10px;
    font-size: 13px;
  }

  @media (max-width: 749px) {
    .eg-grid {
      padding: 36px 16px;
    }

    .eg-grid__items {
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
    }

    .eg-grid__image-wrap img {
      height: 220px;
    }

    .eg-popup__box {
      margin: 35px 16px;
      max-height: 88vh;
      overflow-y: auto;
    }

    .eg-popup__content {
      grid-template-columns: 1fr;
    }

    .eg-popup__image img {
      height: 300px;
    }
  }
</style>

<script>
  (() => {
    const popup = document.getElementById('EgProductPopup');
    const popupImage = document.getElementById('EgPopupImage');
    const popupTitle = document.getElementById('EgPopupTitle');
    const popupPrice = document.getElementById('EgPopupPrice');
    const popupDescription = document.getElementById('EgPopupDescription');
    const popupOptions = document.getElementById('EgPopupOptions');
    const addToCartButton = document.getElementById('EgAddToCart');
    const popupMessage = document.getElementById('EgPopupMessage');

    let currentProduct = null;
    let selectedOptions = [];

    const formatMoney = (cents) => {
      return (cents / 100).toLocaleString('en-US', {
        style: 'currency',
        currency: '{{ cart.currency.iso_code }}'
      });
    };

    const openPopup = () => {
      popup.classList.add('is-open');
      popup.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    const closePopup = () => {
      popup.classList.remove('is-open');
      popup.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      popupMessage.textContent = '';
    };

    const getSelectedVariant = () => {
      if (!currentProduct) return null;

      return currentProduct.variants.find((variant) => {
        return variant.options.every((optionValue, index) => {
          return optionValue === selectedOptions[index];
        });
      });
    };

    const updateSelectedVariant = () => {
      const variant = getSelectedVariant();

      if (variant) {
        popupPrice.textContent = formatMoney(variant.price);
      }

      return variant;
    };

    const renderOptions = () => {
      popupOptions.innerHTML = '';

      currentProduct.options.forEach((optionName, optionIndex) => {
        const values = [...new Set(currentProduct.variants.map((variant) => variant.options[optionIndex]))];

        const optionWrapper = document.createElement('div');
        optionWrapper.className = 'eg-option';

        const label = document.createElement('label');
        label.textContent = optionName;

        const valuesWrapper = document.createElement('div');
        valuesWrapper.className = 'eg-option__values';

        values.forEach((value) => {
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'eg-option__btn';
          button.textContent = value;

          if (selectedOptions[optionIndex] === value) {
            button.classList.add('is-selected');
          }

          button.addEventListener('click', () => {
            selectedOptions[optionIndex] = value;

            valuesWrapper.querySelectorAll('.eg-option__btn').forEach((item) => {
              item.classList.remove('is-selected');
            });

            button.classList.add('is-selected');
            updateSelectedVariant();
          });

          valuesWrapper.appendChild(button);
        });

        optionWrapper.appendChild(label);
        optionWrapper.appendChild(valuesWrapper);
        popupOptions.appendChild(optionWrapper);
      });
    };

    const loadProduct = async (handle) => {
      popupMessage.textContent = 'Loading...';

      try {
        const response = await fetch(`/products/${handle}.js`);
        currentProduct = await response.json();

        selectedOptions = currentProduct.variants[0].options.slice();

        popupImage.src = currentProduct.featured_image || '';
        popupImage.alt = currentProduct.title;
        popupTitle.textContent = currentProduct.title;
        popupDescription.innerHTML = currentProduct.description || '';
        popupMessage.textContent = '';

        renderOptions();
        updateSelectedVariant();
        openPopup();
      } catch (error) {
        popupMessage.textContent = 'Product could not be loaded.';
      }
    };

    const addSoftWinterJacket = async () => {
      try {
        const response = await fetch('/products/soft-winter-jacket.js');
        const jacket = await response.json();

        if (!jacket || !jacket.variants || !jacket.variants[0]) return;

        await fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            id: jacket.variants[0].id,
            quantity: 1
          })
        });
      } catch (error) {
        console.log('Soft Winter Jacket not added');
      }
    };

    document.querySelectorAll('.eg-grid__plus').forEach((button) => {
      button.addEventListener('click', () => {
        loadProduct(button.dataset.productHandle);
      });
    });

    document.querySelectorAll('[data-close-popup]').forEach((button) => {
      button.addEventListener('click', closePopup);
    });

    addToCartButton.addEventListener('click', async () => {
      const variant = updateSelectedVariant();

      if (!variant) {
        popupMessage.textContent = 'Please select available options.';
        return;
      }

      popupMessage.textContent = 'Adding...';

      try {
        await fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            id: variant.id,
            quantity: 1
          })
        });

        const hasBlack = selectedOptions.includes('Black');
        const hasMedium = selectedOptions.includes('Medium');

        if (hasBlack && hasMedium) {
          await addSoftWinterJacket();
        }

        popupMessage.textContent = 'Added to cart successfully.';
      } catch (error) {
        popupMessage.textContent = 'Could not add to cart.';
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Custom Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Choose product"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom Grid"
    }
  ]
}
{% endschema %}