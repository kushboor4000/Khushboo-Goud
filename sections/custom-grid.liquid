<section class="eg-grid">
  <h2>{{ section.settings.heading }}</h2>

  <div class="eg-grid__items">
    {% for block in section.blocks %}
      {% assign product = block.settings.product %}
      {% if product != blank %}
        <div class="eg-grid__card" {{ block.shopify_attributes }}>
          <img
            src="{{ product.featured_image | image_url: width: 900 }}"
            alt="{{ product.title | escape }}"
            width="900"
            height="1100"
            loading="lazy"
          >

          <button
            type="button"
            class="eg-grid__plus"
            data-title="{{ product.title | escape }}"
            data-price="{{ product.price | money }}"
            data-desc="{{ product.description | strip_html | escape }}"
            data-image="{{ product.featured_image | image_url: width: 300 }}"
            data-variants='{{ product.variants | json | escape }}'
            data-options='{{ product.options_with_values | json | escape }}'
            aria-label="Open {{ product.title | escape }}"
          >
            +
          </button>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="eg-popup" id="EgPopup">
    <div class="eg-popup__overlay" data-close></div>

    <div class="eg-popup__box">
      <button type="button" class="eg-popup__close" data-close>×</button>

      <div class="eg-popup__top">
        <img id="EgImage" src="" alt="" width="120" height="140">

        <div class="eg-popup__info">
          <h3 id="EgTitle"></h3>
          <p id="EgPrice"></p>
          <div id="EgDesc"></div>
        </div>
      </div>

      <div class="eg-option">
        <label>Color</label>
        <div class="eg-color-boxes" id="EgColorOptions"></div>
      </div>

      <div class="eg-option">
        <label>Size</label>
        <div class="eg-size-select-wrap">
          <select id="EgSizeSelect">
            <option value="">Choose your size</option>
            <option value="XS">XS</option>
            <option value="S">S</option>
            <option value="M">M</option>
            <option value="L">L</option>
            <option value="XL">XL</option>
          </select>
        </div>
      </div>

      <button type="button" id="EgCartBtn" class="eg-popup__cart">
        ADD TO CART
      </button>

      <p id="EgMessage"></p>
    </div>
  </div>
</section>

<style>
.eg-grid {
  max-width: 1440px;
  margin: -30px auto 0;
  padding: 55px 50px;
  font-family: Arial, sans-serif;
}

.eg-grid h2 {
  font-size: 32px;
  margin: 0 0 28px;
  font-weight: 500;
  text-align: center;
}

.eg-grid__items {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.eg-grid__card {
  position: relative;
  background: #f4f4f4;
  overflow: hidden;
}

.eg-grid__card img {
  width: 100%;
  height: 430px;
  object-fit: cover;
  display: block;
}

.eg-grid__plus {
  position: absolute;
  transform: translate(-50%, -50%);
  width: 22px;
  height: 22px;
  border: 0;
  border-radius: 50%;
  background: #fff;
  color: #000;
  font-size: 18px;
  line-height: 19px;
  cursor: pointer;
  padding: 0;
  z-index: 3;
}

.eg-grid__card:nth-child(1) .eg-grid__plus {
  top: 63%;
  left: 54%;
}

.eg-grid__card:nth-child(2) .eg-grid__plus {
  top: 53%;
  left: 84%;
}

.eg-grid__card:nth-child(3) .eg-grid__plus {
  top: 21%;
  left: 64%;
}

.eg-grid__card:nth-child(4) .eg-grid__plus {
  top: 16%;
  left: 73%;
}

.eg-grid__card:nth-child(5) .eg-grid__plus {
  top: 22%;
  left: 52%;
}

.eg-grid__card:nth-child(6) .eg-grid__plus {
  top: 67%;
  left: 45%;
}

.eg-popup {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 99999;
  align-items: center;
  justify-content: center;
}

.eg-popup.is-open {
  display: flex;
}

.eg-popup__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.eg-popup__box {
  position: relative;
  z-index: 2;
  width: 311px;
  height: 447px;
  padding: 20px 17px 0;
  background: #fff;
  border: 1px solid #000;
  box-sizing: border-box;
  font-family: Arial, sans-serif;
  overflow: hidden;
}

.eg-popup__close {
  position: absolute;
  top: 9px;
  right: 14px;
  background: transparent;
  border: 0;
  color: #000;
  font-size: 26px;
  line-height: 1;
  cursor: pointer;
  padding: 0;
}

.eg-popup__top {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 9px;
  align-items: start;
}

.eg-popup__top img {
  width: 120px;
  height: 140px;
  object-fit: cover;
  display: block;
}

.eg-popup__info {
  padding-top: 3px;
}

.eg-popup h3 {
  margin: 0 20px 11px 0;
  font-size: 16px;
  line-height: 1.22;
  font-weight: 400;
  color: #000;
}

#EgPrice {
  margin: 0 0 13px;
  font-size: 16px;
  line-height: 1.2;
  color: #000;
}

#EgDesc {
  height: 54px;
  overflow: hidden;
  font-size: 12px;
  line-height: 1.12;
  color: #000;
}

.eg-option {
  margin-top: 12px;
}

.eg-option label {
  display: block;
  margin-bottom: 6px;
  color: #000;
  font-size: 13px;
  font-weight: 400;
  line-height: 1;
}

.eg-color-boxes {
  display: grid;
  grid-template-columns: 1fr 1fr;
  height: 41px;
  border: 1px solid #777;
}

.eg-color-btn {
  position: relative;
  border: 0;
  border-right: 1px solid #777;
  background: #fff;
  color: #000;
  padding: 0 11px;
  text-align: left;
  font-size: 16px;
  cursor: pointer;
}

.eg-color-btn:last-child {
  border-right: 0;
}

.eg-color-btn:hover {
  background: #000;
  color: #fff;
}

.eg-color-btn.is-selected {
  background: #000;
  color: #fff;
}

.eg-color-btn.is-selected::before {
  display: none;
}

.eg-size-select-wrap {
  position: relative;
  height: 41px;
  border: 1px solid #777;
}

.eg-size-select-wrap::before {
  content: "";
  position: absolute;
  top: 0;
  right: 53px;
  width: 1px;
  height: 100%;
  background: #777;
  pointer-events: none;
}

.eg-size-select-wrap::after {
  content: "";
  position: absolute;
  right: 17px;
  top: 14px;
  width: 10px;
  height: 10px;
  border-right: 1.5px solid #000;
  border-bottom: 1.5px solid #000;
  transform: rotate(45deg);
  pointer-events: none;
}

#EgSizeSelect {
  width: 100%;
  height: 100%;
  border: 0;
  background: #fff;
  color: #000;
  padding: 0 58px 0 11px;
  font-size: 15px;
  appearance: none;
  cursor: pointer;
}

#EgSizeSelect option:checked {
  background: #000;
  color: #fff;
}

.eg-popup__cart {
  width: 100%;
  height: 45px;
  margin-top: 49px;
  background: #000;
  color: #fff;
  border: 0;
  font-size: 14px;
  font-weight: 400;
  cursor: pointer;
  letter-spacing: 0.2px;
}

.eg-popup__cart::after {
  content: " →";
  font-size: 29px;
  margin-left: 28px;
  vertical-align: -4px;
}

#EgMessage {
  margin: 6px 0 0;
  font-size: 11px;
  line-height: 1.2;
  color: #000;
}

@media (max-width: 749px) {
  .eg-grid {
    margin: -30px auto 0;
    padding: 10px 0 38px;
  }

  .eg-grid h2 {
    font-size: 26px;
    padding: 0 16px;
  }

  .eg-grid__items {
    grid-template-columns: repeat(2, 1fr);
    gap: 3px;
  }

  .eg-grid__card img {
    height: 230px;
  }

  .eg-grid__plus {
    width: 20px;
    height: 20px;
    font-size: 16px;
    line-height: 18px;
  }

  .eg-grid__card:nth-child(1) .eg-grid__plus {
    top: 62%;
    left: 55%;
  }

  .eg-grid__card:nth-child(2) .eg-grid__plus {
    top: 52%;
    left: 84%;
  }

  .eg-grid__card:nth-child(3) .eg-grid__plus {
    top: 20%;
    left: 65%;
  }

  .eg-grid__card:nth-child(4) .eg-grid__plus {
    top: 16%;
    left: 73%;
  }

  .eg-grid__card:nth-child(5) .eg-grid__plus {
    top: 22%;
    left: 52%;
  }

  .eg-grid__card:nth-child(6) .eg-grid__plus {
    top: 67%;
    left: 45%;
  }

  .eg-popup__box {
    width: 311px;
    height: 447px;
  }
}
</style>

<script>
(function () {
  const popup = document.getElementById('EgPopup');
  const image = document.getElementById('EgImage');
  const title = document.getElementById('EgTitle');
  const price = document.getElementById('EgPrice');
  const desc = document.getElementById('EgDesc');
  const colorOptions = document.getElementById('EgColorOptions');
  const sizeSelect = document.getElementById('EgSizeSelect');
  const cartBtn = document.getElementById('EgCartBtn');
  const message = document.getElementById('EgMessage');

  let currentVariants = [];
  let currentOptions = [];
  let selectedColor = '';
  let selectedSize = '';

  function openPopup() {
    popup.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closePopup() {
    popup.classList.remove('is-open');
    document.body.style.overflow = '';
    message.textContent = '';
  }

  function getOptionName(option) {
    return typeof option === 'string' ? option : option.name;
  }

  function getColorValues() {
    const colorOption = currentOptions.find(function (option) {
      return getOptionName(option).toLowerCase().includes('color');
    });

    if (colorOption && colorOption.values && colorOption.values.length) {
      return colorOption.values.slice(0, 2);
    }

    return ['White', 'Black'];
  }

  function findVariant() {
    if (!currentVariants.length) return null;

    return currentVariants.find(function (variant) {
      const opts = variant.options || [];
      const colorMatch = !selectedColor || opts.includes(selectedColor);
      const sizeMatch = !selectedSize || opts.includes(selectedSize);
      return colorMatch && sizeMatch;
    }) || currentVariants[0];
  }

  function renderColors() {
    const colors = getColorValues();
    colorOptions.innerHTML = '';
    selectedColor = colors[0] || '';

    colors.forEach(function (color, index) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'eg-color-btn';
      btn.textContent = color;

      if (index === 0) {
        btn.classList.add('is-selected');
      }

      btn.addEventListener('click', function () {
        selectedColor = color;

        colorOptions.querySelectorAll('.eg-color-btn').forEach(function (item) {
          item.classList.remove('is-selected');
        });

        btn.classList.add('is-selected');
      });

      colorOptions.appendChild(btn);
    });
  }

  function loadPopup(btn) {
    title.textContent = btn.dataset.title || '';
    price.textContent = btn.dataset.price || '';
    desc.textContent = btn.dataset.desc || '';
    image.src = btn.dataset.image || '';
    image.alt = btn.dataset.title || '';
    message.textContent = '';

    try {
      currentVariants = JSON.parse(btn.dataset.variants || '[]');
      currentOptions = JSON.parse(btn.dataset.options || '[]');
    } catch (error) {
      currentVariants = [];
      currentOptions = [];
    }

    selectedSize = '';
    sizeSelect.value = '';

    renderColors();
    openPopup();
  }

  document.querySelectorAll('.eg-grid__plus').forEach(function (btn) {
    btn.addEventListener('click', function () {
      loadPopup(btn);
    });
  });

  sizeSelect.addEventListener('change', function () {
    selectedSize = sizeSelect.value;
  });

  document.querySelectorAll('[data-close]').forEach(function (btn) {
    btn.addEventListener('click', closePopup);
  });

  document.addEventListener('keydown', function (event) {
    if (event.key === 'Escape') closePopup();
  });

  cartBtn.addEventListener('click', async function () {
    if (!selectedSize) {
      message.textContent = 'Please choose your size.';
      return;
    }

    const variant = findVariant();

    if (!variant || !variant.id) {
      message.textContent = 'Selected variant is not available.';
      return;
    }

    message.textContent = 'Adding...';

    try {
      const root = window.Shopify && window.Shopify.routes && window.Shopify.routes.root
        ? window.Shopify.routes.root
        : '/';

      await fetch(root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: variant.id,
          quantity: 1
        })
      });

      message.textContent = 'Added to cart.';
    } catch (error) {
      message.textContent = 'Could not add to cart.';
    }
  });
})();
</script>

{% schema %}
{
  "name": "Custom Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Choose product"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom Grid"
    }
  ]
}
{% endschema %}
