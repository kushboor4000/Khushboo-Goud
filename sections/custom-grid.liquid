<section class="eg-product-grid-section" id="EgProductGrid-{{ section.id }}">
  <div class="eg-grid-container">
    <h2>{{ section.settings.heading }}</h2>

    <div class="eg-product-grid">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        {% if product != blank %}
          <button type="button" class="eg-product-card" {{ block.shopify_attributes }}>
            <span class="eg-hotspot">+</span>

            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 700 }}"
                alt="{{ product.title | escape }}"
                loading="lazy">
            {% endif %}

            <div class="eg-product-info">
              <h3>{{ product.title }}</h3>
              <p>{{ product.price | money }}</p>
            </div>

            <script type="application/json" class="eg-product-json">
              {{ product | json }}
            </script>
          </button>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="eg-popup-overlay" hidden>
    <div class="eg-popup" role="dialog" aria-modal="true">
      <button type="button" class="eg-popup-close" aria-label="Close popup">×</button>

      <div class="eg-popup-image-wrap">
        <img class="eg-popup-image" src="" alt="">
      </div>

      <div class="eg-popup-content">
        <h3 class="eg-popup-title"></h3>
        <p class="eg-popup-price"></p>
        <div class="eg-popup-description"></div>

        <form class="eg-product-form">
          <div class="eg-variant-options"></div>
          <input type="hidden" name="id" class="eg-selected-variant-id">

          <button type="submit" class="eg-add-to-cart">ADD TO CART</button>
          <p class="eg-cart-message" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
.eg-product-grid-section,
.eg-product-grid-section * {
  box-sizing: border-box;
  font-family: Jost, Arial, Helvetica, sans-serif;
}

.eg-product-grid-section {
  width: 100%;
  background: #fff;
  color: #000;
  padding: 70px 20px;
}

.eg-grid-container {
  max-width: 1280px;
  margin: 0 auto;
}

.eg-grid-container h2 {
  margin: 0 0 36px;
  text-align: center;
  font-size: 36px;
  line-height: 1.1;
  font-weight: 500;
}

.eg-product-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}

.eg-product-card {
  position: relative;
  display: block;
  width: 100%;
  min-height: 390px;
  padding: 0;
  border: 0;
  background: #f4f4f4;
  cursor: pointer;
  overflow: hidden;
  text-align: left;
}

.eg-product-card img {
  width: 100%;
  height: 330px;
  display: block;
  object-fit: cover;
  transition: transform .35s ease;
}

.eg-product-card:hover img {
  transform: scale(1.04);
}

.eg-hotspot {
  position: absolute;
  top: 18px;
  right: 18px;
  width: 28px;
  height: 28px;
  background: #fff544;
  color: #000;
  border-radius: 50%;
  display: grid;
  place-items: center;
  font-size: 22px;
  line-height: 1;
  z-index: 2;
}

.eg-product-info {
  padding: 16px;
  background: #fff;
}

.eg-product-info h3 {
  margin: 0 0 6px;
  font-size: 18px;
  font-weight: 500;
}

.eg-product-info p {
  margin: 0;
  font-size: 15px;
}

.eg-popup-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0,0,0,.55);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
}

.eg-popup-overlay[hidden] {
  display: none;
}

.eg-popup {
  position: relative;
  width: min(900px, 100%);
  max-height: 90vh;
  overflow: auto;
  background: #fff;
  display: grid;
  grid-template-columns: 1fr 1fr;
}

.eg-popup-close {
  position: absolute;
  top: 14px;
  right: 14px;
  width: 34px;
  height: 34px;
  border: 0;
  background: #000;
  color: #fff;
  font-size: 24px;
  line-height: 1;
  cursor: pointer;
  z-index: 3;
}

.eg-popup-image-wrap {
  background: #f4f4f4;
}

.eg-popup-image {
  width: 100%;
  height: 100%;
  min-height: 520px;
  object-fit: cover;
  display: block;
}

.eg-popup-content {
  padding: 48px 34px 34px;
}

.eg-popup-title {
  margin: 0 0 10px;
  font-size: 28px;
  line-height: 1.1;
  font-weight: 500;
}

.eg-popup-price {
  margin: 0 0 20px;
  font-size: 18px;
}

.eg-popup-description {
  margin-bottom: 24px;
  font-size: 14px;
  line-height: 1.5;
}

.eg-option-group {
  margin-bottom: 20px;
}

.eg-option-label {
  display: block;
  margin-bottom: 10px;
  font-size: 14px;
  font-weight: 500;
}

.eg-option-values {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.eg-option-button {
  min-width: 64px;
  min-height: 42px;
  border: 1px solid #000;
  background: #fff;
  color: #000;
  padding: 10px 14px;
  cursor: pointer;
  font-size: 14px;
}

.eg-option-button.is-active {
  background: #000;
  color: #fff;
}

.eg-add-to-cart {
  width: 100%;
  height: 52px;
  border: 0;
  background: #000;
  color: #fff;
  font-size: 14px;
  cursor: pointer;
  letter-spacing: .4px;
}

.eg-add-to-cart:disabled {
  opacity: .6;
  cursor: not-allowed;
}

.eg-cart-message {
  margin: 12px 0 0;
  font-size: 14px;
  color: #008000;
}

@media (max-width: 749px) {
  .eg-product-grid-section {
    padding: 46px 16px;
  }

  .eg-grid-container h2 {
    font-size: 28px;
    margin-bottom: 24px;
  }

  .eg-product-grid {
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .eg-product-card {
    min-height: auto;
  }

  .eg-product-card img {
    height: 360px;
  }

  .eg-popup {
    grid-template-columns: 1fr;
  }

  .eg-popup-image {
    min-height: 280px;
    height: 280px;
  }

  .eg-popup-content {
    padding: 34px 22px 24px;
  }

  .eg-popup-title {
    font-size: 24px;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const section = document.getElementById('EgProductGrid-{{ section.id }}');
  if (!section) return;

  const productCards = section.querySelectorAll('.eg-product-card');
  const overlay = section.querySelector('.eg-popup-overlay');
  const closeBtn = section.querySelector('.eg-popup-close');
  const popupImage = section.querySelector('.eg-popup-image');
  const popupTitle = section.querySelector('.eg-popup-title');
  const popupPrice = section.querySelector('.eg-popup-price');
  const popupDescription = section.querySelector('.eg-popup-description');
  const optionsWrap = section.querySelector('.eg-variant-options');
  const variantInput = section.querySelector('.eg-selected-variant-id');
  const form = section.querySelector('.eg-product-form');
  const addBtn = section.querySelector('.eg-add-to-cart');
  const message = section.querySelector('.eg-cart-message');

  const moneyFormat = {{ shop.money_format | json }};
  const softWinterJacketVariantId = {{ section.settings.soft_winter_jacket.selected_or_first_available_variant.id | default: 'null' }};

  let currentProduct = null;
  let selectedOptions = [];

  function formatMoney(cents) {
    if (window.Shopify && Shopify.formatMoney) {
      return Shopify.formatMoney(cents, moneyFormat);
    }

    return (cents / 100).toLocaleString('en-IN', {
      style: 'currency',
      currency: '{{ cart.currency.iso_code }}'
    });
  }

  function getProductImage(product) {
    if (product.featured_image) return product.featured_image;
    if (product.images && product.images.length) return product.images[0];
    return '';
  }

  function findSelectedVariant() {
    return currentProduct.variants.find(function (variant) {
      return variant.options.every(function (option, index) {
        return option === selectedOptions[index];
      });
    });
  }

  function updateSelectedVariant() {
    const selectedVariant = findSelectedVariant();

    if (!selectedVariant) {
      variantInput.value = '';
      addBtn.disabled = true;
      addBtn.textContent = 'UNAVAILABLE';
      return;
    }

    variantInput.value = selectedVariant.id;
    popupPrice.textContent = formatMoney(selectedVariant.price);
    addBtn.disabled = !selectedVariant.available;
    addBtn.textContent = selectedVariant.available ? 'ADD TO CART' : 'SOLD OUT';
  }

  function renderOptions(product) {
    optionsWrap.innerHTML = '';

    product.options.forEach(function (optionName, optionIndex) {
      const values = [];

      product.variants.forEach(function (variant) {
        const value = variant.options[optionIndex];
        if (!values.includes(value)) values.push(value);
      });

      const group = document.createElement('div');
      group.className = 'eg-option-group';

      const label = document.createElement('span');
      label.className = 'eg-option-label';
      label.textContent = optionName;

      const valueWrap = document.createElement('div');
      valueWrap.className = 'eg-option-values';

      values.forEach(function (value) {
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'eg-option-button';
        button.textContent = value;

        if (selectedOptions[optionIndex] === value) {
          button.classList.add('is-active');
        }

        button.addEventListener('click', function () {
          selectedOptions[optionIndex] = value;

          valueWrap.querySelectorAll('.eg-option-button').forEach(function (btn) {
            btn.classList.remove('is-active');
          });

          button.classList.add('is-active');
          updateSelectedVariant();
        });

        valueWrap.appendChild(button);
      });

      group.appendChild(label);
      group.appendChild(valueWrap);
      optionsWrap.appendChild(group);
    });
  }

  function openPopup(product) {
    currentProduct = product;
    selectedOptions = product.variants[0] ? [...product.variants[0].options] : [];

    popupTitle.textContent = product.title;
    popupPrice.textContent = product.price ? formatMoney(product.price) : '';
    popupDescription.innerHTML = product.description || '';

    popupImage.src = getProductImage(product);
    popupImage.alt = product.title;

    renderOptions(product);
    updateSelectedVariant();

    message.textContent = '';
    overlay.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function closePopup() {
    overlay.hidden = true;
    document.body.style.overflow = '';
  }

  function shouldAddSoftWinterJacket() {
    const selectedValues = selectedOptions.map(function (value) {
      return String(value).toLowerCase();
    });

    return selectedValues.includes('black') && selectedValues.includes('medium');
  }

  async function addItemsToCart(items) {
    const response = await fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({ items: items })
    });

    if (!response.ok) {
      throw new Error('Product could not be added to cart');
    }

    return response.json();
  }

  async function getCart() {
    const response = await fetch('/cart.js', {
      method: 'GET',
      headers: {
        'Accept': 'application/json'
      }
    });

    return response.json();
  }

  function updateCartCount(cart) {
    const cartIcon = document.querySelector('#cart-icon-bubble');
    if (!cartIcon) return;

    let bubble = cartIcon.querySelector('.cart-count-bubble');

    if (!bubble) {
      bubble = document.createElement('div');
      bubble.className = 'cart-count-bubble';
      bubble.innerHTML = '<span aria-hidden="true"></span><span class="visually-hidden"></span>';
      cartIcon.appendChild(bubble);
    }

    const visibleCount = bubble.querySelector('span[aria-hidden="true"]');
    const hiddenCount = bubble.querySelector('.visually-hidden');

    if (visibleCount) visibleCount.textContent = cart.item_count;
    if (hiddenCount) hiddenCount.textContent = cart.item_count + ' items';
  }

  function showSuccess(extraProductAdded) {
    message.textContent = extraProductAdded
      ? 'Added to cart with Soft Winter Jacket.'
      : 'Added to cart.';

    addBtn.textContent = 'ADDED';

    setTimeout(function () {
      addBtn.disabled = false;
      addBtn.textContent = 'ADD TO CART';
      message.textContent = '';
    }, 1800);
  }

  productCards.forEach(function (card) {
    card.addEventListener('click', function () {
      const jsonScript = card.querySelector('.eg-product-json');
      if (!jsonScript) return;

      const product = JSON.parse(jsonScript.textContent);
      openPopup(product);
    });
  });

  closeBtn.addEventListener('click', closePopup);

  overlay.addEventListener('click', function (event) {
    if (event.target === overlay) closePopup();
  });

  document.addEventListener('keydown', function (event) {
    if (event.key === 'Escape' && !overlay.hidden) closePopup();
  });

  form.addEventListener('submit', async function (event) {
    event.preventDefault();

    const variantId = Number(variantInput.value);
    if (!variantId) return;

    const extraProductAdded = shouldAddSoftWinterJacket() && softWinterJacketVariantId;

    const items = [
      {
        id: variantId,
        quantity: 1
      }
    ];

    if (extraProductAdded) {
      items.push({
        id: softWinterJacketVariantId,
        quantity: 1
      });
    }

    addBtn.disabled = true;
    addBtn.textContent = 'ADDING...';
    message.textContent = '';

    try {
      await addItemsToCart(items);

      const cart = await getCart();
      updateCartCount(cart);
      showSuccess(extraProductAdded);

      document.documentElement.dispatchEvent(
        new CustomEvent('cart:refresh', {
          bubbles: true,
          detail: { cart: cart }
        })
      );
    } catch (error) {
      message.textContent = 'Unable to add. Please try again.';
      addBtn.disabled = false;
      addBtn.textContent = 'ADD TO CART';
      console.error(error);
    }
  });
});
</script>

{% schema %}
{
  "name": "EG Product Grid Popup",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Grid heading",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "product",
      "id": "soft_winter_jacket",
      "label": "Soft Winter Jacket product"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Grid product",
      "limit": 6,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "EG Product Grid Popup",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
