<section class="tisso-grid">
  <h2>{{ section.settings.heading }}</h2>

  <div class="tisso-grid__items">
    {% for block in section.blocks %}
      {% assign product = block.settings.product %}
      {% if product != blank %}
        <div
          class="tisso-grid__item"
          style="--plus-x: {{ block.settings.plus_x }}%; --plus-y: {{ block.settings.plus_y }}%;"
          {{ block.shopify_attributes }}
        >
          <img
            src="{{ product.featured_image | image_url: width: 900 }}"
            alt="{{ product.title | escape }}"
            width="900"
            height="1100"
            loading="lazy"
          >

          <button
            type="button"
            class="tisso-grid__plus"
            data-product-handle="{{ product.handle }}"
            aria-label="Open {{ product.title | escape }}"
          >
            +
          </button>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="tisso-popup" id="TissoPopup" aria-hidden="true">
    <div class="tisso-popup__overlay" data-close-popup></div>

    <div class="tisso-popup__box">
      <button type="button" class="tisso-popup__close" data-close-popup>×</button>

      <div class="tisso-popup__top">
        <img id="TissoPopupImage" src="" alt="" width="140" height="170">

        <div class="tisso-popup__info">
          <h3 id="TissoPopupTitle"></h3>
          <p id="TissoPopupPrice"></p>
          <div id="TissoPopupDescription"></div>
        </div>
      </div>

      <div id="TissoColorBox"></div>
      <div id="TissoSizeBox"></div>

      <button type="button" id="TissoAddToCart" class="tisso-popup__cart">
        ADD TO CART <span>→</span>
      </button>

      <p id="TissoMessage" class="tisso-popup__message"></p>
    </div>
  </div>
</section>

<style>
.tisso-grid {
  max-width: 1440px;
  margin: 0 auto;
  padding: 86px 176px 88px;
  font-family: Georgia, 'Times New Roman', serif;
  color: #000;
  background: #fff;
}

.tisso-grid h2 {
  margin: 0 0 42px;
  text-align: left;
  font-size: 31px;
  line-height: 1;
  font-weight: 400;
}

.tisso-grid__items {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.tisso-grid__item {
  position: relative;
  aspect-ratio: 1 / 1.28;
  overflow: hidden;
  background: #f5f5f5;
}

.tisso-grid__item img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

.tisso-grid__plus {
  position: absolute;
  left: var(--plus-x, 55%);
  top: var(--plus-y, 55%);
  width: 19px;
  height: 19px;
  border: 0;
  border-radius: 50%;
  background: #f8f3df;
  color: #000;
  font-family: Arial, Helvetica, sans-serif;
  font-size: 16px;
  line-height: 17px;
  padding: 0;
  cursor: pointer;
  transform: translate(-50%, -50%);
  z-index: 3;
}

.tisso-popup {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 99999;
  font-family: Arial, Helvetica, sans-serif;
}

.tisso-popup.is-open {
  display: block;
}

.tisso-popup__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,.18);
}

.tisso-popup__box {
  position: relative;
  z-index: 2;
  width: 390px;
  min-height: 448px;
  margin: 60px auto;
  background: #fff;
  border: 1px solid #000;
  padding: 24px 24px 28px;
  box-sizing: border-box;
  color: #000;
}

.tisso-popup__close {
  position: absolute;
  top: 12px;
  right: 16px;
  border: 0;
  background: transparent;
  color: #000;
  font-size: 26px;
  line-height: 1;
  cursor: pointer;
  padding: 0;
}

.tisso-popup__top {
  display: grid;
  grid-template-columns: 140px 1fr;
  gap: 12px;
  margin-bottom: 12px;
}

.tisso-popup__top img {
  width: 140px;
  height: 170px;
  display: block;
  object-fit: cover;
  background: #f5f5f5;
}

.tisso-popup__info h3 {
  margin: 8px 26px 12px 0;
  font-size: 18px;
  line-height: 1.18;
  font-weight: 400;
}

.tisso-popup__info p {
  margin: 0 0 12px;
  font-size: 19px;
  line-height: 1;
}

#TissoPopupDescription {
  max-height: 76px;
  overflow: hidden;
  font-size: 14px;
  line-height: 1.08;
}

.tisso-option {
  margin-bottom: 14px;
}

.tisso-option__label {
  display: block;
  margin: 0 0 7px;
  font-size: 14px;
  font-weight: 400;
}

.tisso-colors {
  display: grid;
  grid-template-columns: 1fr 1fr;
  border: 1px solid #000;
  height: 50px;
}

.tisso-color {
  position: relative;
  min-width: 0;
  border: 0;
  border-right: 1px solid #000;
  background: #fff;
  color: #000;
  font-size: 18px;
  text-align: left;
  padding: 0 12px 0 20px;
  cursor: pointer;
}

.tisso-color:last-child {
  border-right: 0;
}

.tisso-color::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  width: 5px;
  height: 100%;
  background: var(--swatch-color, #000);
}

.tisso-color.is-selected {
  box-shadow: inset 0 0 0 2px #000;
}

.tisso-size-wrap {
  position: relative;
}

.tisso-size {
  width: 100%;
  height: 50px;
  border: 1px solid #000;
  background: #fff;
  color: #000;
  font-size: 16px;
  padding: 0 54px 0 14px;
  appearance: none;
  cursor: pointer;
}

.tisso-size-wrap::after {
  content: "⌄";
  position: absolute;
  right: 0;
  top: 0;
  width: 54px;
  height: 50px;
  border-left: 1px solid #000;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  pointer-events: none;
}

.tisso-popup__cart {
  width: 100%;
  height: 56px;
  margin-top: 34px;
  border: 0;
  background: #000;
  color: #fff;
  font-size: 16px;
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 46px;
  cursor: pointer;
}

.tisso-popup__cart span {
  font-size: 31px;
  line-height: 1;
}

.tisso-popup__message {
  margin: 10px 0 0;
  font-size: 13px;
}

@media screen and (max-width: 749px) {
  .tisso-grid {
    padding: 39px 20px 26px;
  }

  .tisso-grid h2 {
    text-align: center;
    font-size: 28px;
    line-height: 1.08;
    margin-bottom: 24px;
  }

  .tisso-grid__items {
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;
  }

  .tisso-grid__item {
    aspect-ratio: 1 / 1.28;
  }

  .tisso-grid__plus {
    width: 18px;
    height: 18px;
    font-size: 15px;
    line-height: 16px;
  }

  .tisso-popup__box {
    width: calc(100% - 32px);
    max-width: 390px;
    min-height: 448px;
    margin: 14px auto;
    padding: 24px 20px 28px;
    max-height: calc(100vh - 28px);
    overflow-y: auto;
  }

  .tisso-popup__top {
    grid-template-columns: 120px 1fr;
    gap: 10px;
  }

  .tisso-popup__top img {
    width: 120px;
    height: 140px;
  }

  .tisso-popup__info h3 {
    font-size: 16px;
    margin-top: 6px;
  }

  .tisso-popup__info p {
    font-size: 17px;
  }

  #TissoPopupDescription {
    font-size: 12px;
    line-height: 1.1;
  }

  .tisso-color {
    font-size: 16px;
  }
}
</style>

<script>
(function () {
  const popup = document.getElementById('TissoPopup');
  const popupImage = document.getElementById('TissoPopupImage');
  const popupTitle = document.getElementById('TissoPopupTitle');
  const popupPrice = document.getElementById('TissoPopupPrice');
  const popupDescription = document.getElementById('TissoPopupDescription');
  const colorBox = document.getElementById('TissoColorBox');
  const sizeBox = document.getElementById('TissoSizeBox');
  const addButton = document.getElementById('TissoAddToCart');
  const message = document.getElementById('TissoMessage');

  let currentProduct = null;
  let selectedOptions = [];

  const colorMap = {
    White: '#ffffff',
    Black: '#000000',
    Grey: '#b8b8b8',
    Gray: '#b8b8b8',
    Red: '#c90035',
    Blue: '#1f57c8'
  };

  function money(cents) {
    return (cents / 100).toLocaleString('en-US', {
      style: 'currency',
      currency: '{{ cart.currency.iso_code }}'
    });
  }

  function openPopup() {
    popup.classList.add('is-open');
    popup.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closePopup() {
    popup.classList.remove('is-open');
    popup.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    message.textContent = '';
  }

  function getVariant() {
    if (!currentProduct) return null;

    return currentProduct.variants.find(function (variant) {
      return variant.options.every(function (value, index) {
        return value === selectedOptions[index];
      });
    });
  }

  function updatePrice() {
    const variant = getVariant();
    if (variant) {
      popupPrice.textContent = money(variant.price);
    }
  }

  function getValues(optionIndex) {
    const values = [];
    currentProduct.variants.forEach(function (variant) {
      const value = variant.options[optionIndex];
      if (!values.includes(value)) values.push(value);
    });
    return values;
  }

  function renderColorOption(optionName, optionIndex) {
    const wrapper = document.createElement('div');
    wrapper.className = 'tisso-option';

    const label = document.createElement('label');
    label.className = 'tisso-option__label';
    label.textContent = optionName;

    const valuesWrapper = document.createElement('div');
    valuesWrapper.className = 'tisso-colors';

    getValues(optionIndex).slice(0, 2).forEach(function (value) {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'tisso-color';
      button.textContent = value;
      button.style.setProperty('--swatch-color', colorMap[value] || '#000');

      if (selectedOptions[optionIndex] === value) {
        button.classList.add('is-selected');
      }

      button.addEventListener('click', function () {
        selectedOptions[optionIndex] = value;

        valuesWrapper.querySelectorAll('.tisso-color').forEach(function (item) {
          item.classList.remove('is-selected');
        });

        button.classList.add('is-selected');
        updatePrice();
      });

      valuesWrapper.appendChild(button);
    });

    wrapper.appendChild(label);
    wrapper.appendChild(valuesWrapper);
    colorBox.appendChild(wrapper);
  }

  function renderSizeOption(optionName, optionIndex) {
    const wrapper = document.createElement('div');
    wrapper.className = 'tisso-option';

    const label = document.createElement('label');
    label.className = 'tisso-option__label';
    label.textContent = optionName;

    const selectWrap = document.createElement('div');
    selectWrap.className = 'tisso-size-wrap';

    const select = document.createElement('select');
    select.className = 'tisso-size';

    const placeholder = document.createElement('option');
    placeholder.textContent = 'Choose your size';
    placeholder.value = '';
    select.appendChild(placeholder);

    getValues(optionIndex).forEach(function (value) {
      const option = document.createElement('option');
      option.value = value;
      option.textContent = value;
      select.appendChild(option);
    });

    select.addEventListener('change', function () {
      if (select.value) {
        selectedOptions[optionIndex] = select.value;
        updatePrice();
      }
    });

    selectWrap.appendChild(select);
    wrapper.appendChild(label);
    wrapper.appendChild(selectWrap);
    sizeBox.appendChild(wrapper);
  }

  function renderOptions() {
    colorBox.innerHTML = '';
    sizeBox.innerHTML = '';

    currentProduct.options.forEach(function (optionName, index) {
      const lowerName = optionName.toLowerCase();

      if (lowerName.includes('color') || lowerName.includes('colour')) {
        renderColorOption(optionName, index);
      } else if (lowerName.includes('size')) {
        renderSizeOption(optionName, index);
      }
    });
  }

  async function loadProduct(handle) {
    message.textContent = 'Loading...';

    try {
      const response = await fetch('/products/' + handle + '.js');
      currentProduct = await response.json();

      selectedOptions = currentProduct.variants[0].options.slice();

      popupImage.src = currentProduct.featured_image || '';
      popupImage.alt = currentProduct.title;
      popupTitle.textContent = currentProduct.title;
      popupPrice.textContent = money(currentProduct.variants[0].price);
      popupDescription.innerHTML = currentProduct.description || 'This one-piece swimsuit is crafted from jersey featuring an allover micro Monogram motif in relief.';

      renderOptions();
      updatePrice();
      message.textContent = '';
      openPopup();
    } catch (error) {
      message.textContent = 'Product could not be loaded.';
    }
  }

  async function addSoftWinterJacket() {
    try {
      const response = await fetch('/products/soft-winter-jacket.js');
      const jacket = await response.json();

      if (!jacket.variants || !jacket.variants[0]) return;

      await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: jacket.variants[0].id, quantity: 1 })
      });
    } catch (error) {
      console.log('Soft Winter Jacket not added');
    }
  }

  document.querySelectorAll('.tisso-grid__plus').forEach(function (button) {
    button.addEventListener('click', function () {
      loadProduct(button.dataset.productHandle);
    });
  });

  document.querySelectorAll('[data-close-popup]').forEach(function (item) {
    item.addEventListener('click', closePopup);
  });

  document.addEventListener('keydown', function (event) {
    if (event.key === 'Escape') closePopup();
  });

  addButton.addEventListener('click', async function () {
    const variant = getVariant();

    if (!variant) {
      message.textContent = 'Please select available options.';
      return;
    }

    message.textContent = 'Adding...';

    try {
      await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variant.id, quantity: 1 })
      });

      const hasBlack = selectedOptions.includes('Black');
      const hasMedium = selectedOptions.includes('Medium') || selectedOptions.includes('M');

      if (hasBlack && hasMedium) {
        await addSoftWinterJacket();
      }

      message.textContent = 'Added to cart.';
    } catch (error) {
      message.textContent = 'Could not add to cart.';
    }
  });
})();
</script>

{% schema %}
{
  "name": "Custom Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Choose product"
        },
        {
          "type": "range",
          "id": "plus_x",
          "label": "Plus icon horizontal position",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 55
        },
        {
          "type": "range",
          "id": "plus_y",
          "label": "Plus icon vertical position",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 55
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom Grid"
    }
  ]
}
{% endschema %}
