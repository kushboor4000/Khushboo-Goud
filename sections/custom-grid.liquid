<section class="eg-grid">
  <h2>{{ section.settings.heading }}</h2>

  <div class="eg-grid__items">
    {% for block in section.blocks %}
      {% assign product = block.settings.product %}
      {% if product != blank %}
        <div
          class="eg-grid__card"
          style="--plus-x: {{ block.settings.plus_x }}%; --plus-y: {{ block.settings.plus_y }}%;"
          {{ block.shopify_attributes }}
        >
          <img
            src="{{ product.featured_image | image_url: width: 800 }}"
            alt="{{ product.title | escape }}"
            width="800"
            height="1000"
            loading="lazy"
          >

          <button
            type="button"
            class="eg-grid__plus"
            data-handle="{{ product.handle }}"
            aria-label="Open {{ product.title | escape }}"
          >
            +
          </button>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="eg-popup" id="EgPopup">
    <div class="eg-popup__overlay" data-close></div>

    <div class="eg-popup__box">
      <button type="button" class="eg-popup__close" data-close>×</button>

      <div class="eg-popup__top">
        <img id="EgImage" src="" alt="" width="140" height="170">

        <div class="eg-popup__info">
          <h3 id="EgTitle"></h3>
          <p id="EgPrice"></p>
          <div id="EgDesc"></div>
        </div>
      </div>

      <div id="EgOptions"></div>

      <button type="button" id="EgCartBtn" class="eg-popup__cart">
        ADD TO CART <span>→</span>
      </button>

      <p id="EgMessage" class="eg-popup__message"></p>
    </div>
  </div>
</section>

<style>
.eg-grid {
  max-width: 1440px;
  margin: 0 auto;
  padding: 86px 176px 88px;
  background: #fff;
  color: #000;
  font-family: Georgia, 'Times New Roman', serif;
}

.eg-grid h2 {
  margin: 0 0 42px;
  font-size: 31px;
  line-height: 1;
  font-weight: 400;
}

.eg-grid__items {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.eg-grid__card {
  position: relative;
  aspect-ratio: 1 / 1.28;
  overflow: hidden;
  background: #f4f4f4;
}

.eg-grid__card img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

.eg-grid__plus {
  position: absolute;
  left: var(--plus-x, 55%);
  top: var(--plus-y, 18%);
  width: 19px;
  height: 19px;
  border: 0;
  border-radius: 50%;
  background: #f8f3df;
  color: #000;
  font-family: Arial, Helvetica, sans-serif;
  font-size: 16px;
  line-height: 18px;
  padding: 0;
  cursor: pointer;
  transform: translate(-50%, -50%);
  z-index: 3;
}

.eg-popup {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 99999;
  font-family: Arial, Helvetica, sans-serif;
}

.eg-popup.is-open {
  display: block;
}

.eg-popup__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,.18);
}

.eg-popup__box {
  position: relative;
  z-index: 2;
  width: 390px;
  min-height: 448px;
  margin: 60px auto;
  background: #fff;
  border: 1px solid #000;
  padding: 24px 24px 28px;
  box-sizing: border-box;
  color: #000;
}

.eg-popup__close {
  position: absolute;
  top: 12px;
  right: 16px;
  border: 0;
  background: transparent;
  color: #000;
  font-size: 26px;
  line-height: 1;
  cursor: pointer;
  padding: 0;
}

.eg-popup__top {
  display: grid;
  grid-template-columns: 140px 1fr;
  gap: 12px;
  margin-bottom: 12px;
}

.eg-popup__top img {
  width: 140px;
  height: 170px;
  object-fit: cover;
  background: #f5f5f5;
}

.eg-popup__info h3 {
  margin: 8px 26px 12px 0;
  font-size: 18px;
  line-height: 1.18;
  font-weight: 400;
}

.eg-popup__info p {
  margin: 0 0 12px;
  font-size: 19px;
  line-height: 1;
}

#EgDesc {
  max-height: 76px;
  overflow: hidden;
  font-size: 14px;
  line-height: 1.08;
}

.eg-option {
  margin-bottom: 14px;
}

.eg-option__label {
  display: block;
  margin: 0 0 7px;
  font-size: 14px;
  font-weight: 400;
}

.eg-colors {
  display: grid;
  grid-template-columns: 1fr 1fr;
  height: 50px;
  border: 1px solid #000;
}

.eg-color {
  position: relative;
  border: 0;
  border-right: 1px solid #000;
  background: #fff;
  color: #000;
  font-size: 18px;
  text-align: left;
  padding: 0 12px 0 20px;
  cursor: pointer;
}

.eg-color:last-child {
  border-right: 0;
}

.eg-color::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  width: 5px;
  height: 100%;
  background: var(--swatch-color, #000);
}

.eg-color.is-selected {
  box-shadow: inset 0 0 0 2px #000;
}

.eg-size-wrap {
  position: relative;
}

.eg-size {
  width: 100%;
  height: 50px;
  border: 1px solid #000;
  background: #fff;
  color: #000;
  font-size: 16px;
  padding: 0 54px 0 14px;
  appearance: none;
  cursor: pointer;
}

.eg-size-wrap::after {
  content: "⌄";
  position: absolute;
  right: 0;
  top: 0;
  width: 54px;
  height: 50px;
  border-left: 1px solid #000;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  pointer-events: none;
}

.eg-popup__cart {
  width: 100%;
  height: 56px;
  margin-top: 34px;
  border: 0;
  background: #000;
  color: #fff;
  font-size: 16px;
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 46px;
  cursor: pointer;
}

.eg-popup__cart span {
  font-size: 31px;
  line-height: 1;
}

.eg-popup__message {
  margin: 10px 0 0;
  font-size: 13px;
}

@media (max-width: 749px) {
  .eg-grid {
    padding: 39px 20px 26px;
  }

  .eg-grid h2 {
    text-align: center;
    font-size: 28px;
    line-height: 1.08;
    margin-bottom: 24px;
  }

  .eg-grid__items {
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;
  }

  .eg-grid__card {
    aspect-ratio: 1 / 1.28;
  }

  .eg-grid__plus {
    width: 18px;
    height: 18px;
    font-size: 15px;
    line-height: 17px;
  }

  .eg-popup__box {
    width: calc(100% - 32px);
    max-width: 390px;
    min-height: 448px;
    margin: 14px auto;
    padding: 24px 20px 28px;
    max-height: calc(100vh - 28px);
    overflow-y: auto;
  }

  .eg-popup__top {
    grid-template-columns: 120px 1fr;
    gap: 10px;
  }

  .eg-popup__top img {
    width: 120px;
    height: 140px;
  }

  .eg-popup__info h3 {
    font-size: 16px;
    margin-top: 6px;
  }

  .eg-popup__info p {
    font-size: 17px;
  }

  #EgDesc {
    font-size: 12px;
    line-height: 1.1;
  }

  .eg-color {
    font-size: 16px;
  }
}
</style>

<script>
(function () {
  function initEgGrid() {
    const popup = document.getElementById('EgPopup');
    const image = document.getElementById('EgImage');
    const title = document.getElementById('EgTitle');
    const price = document.getElementById('EgPrice');
    const desc = document.getElementById('EgDesc');
    const optionsBox = document.getElementById('EgOptions');
    const cartBtn = document.getElementById('EgCartBtn');
    const message = document.getElementById('EgMessage');

    if (!popup || !image || !title || !price || !desc || !optionsBox || !cartBtn) return;

    let currentProduct = null;
    let selectedOptions = [];

    function money(cents) {
      return (cents / 100).toLocaleString('en-US', {
        style: 'currency',
        currency: '{{ cart.currency.iso_code }}'
      });
    }

    function openPopup() {
      popup.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }

    function closePopup() {
      popup.classList.remove('is-open');
      document.body.style.overflow = '';
      if (message) message.textContent = '';
    }

    function selectedVariant() {
      if (!currentProduct) return null;

      return currentProduct.variants.find(function (variant) {
        return variant.options.every(function (value, index) {
          return value === selectedOptions[index];
        });
      });
    }

    function updatePrice() {
      const variant = selectedVariant();
      if (variant) price.textContent = money(variant.price);
    }

    function renderOptions() {
      optionsBox.innerHTML = '';

      currentProduct.options.forEach(function (optionName, optionIndex) {
        const values = [];

        currentProduct.variants.forEach(function (variant) {
          const value = variant.options[optionIndex];
          if (!values.includes(value)) values.push(value);
        });

        const wrap = document.createElement('div');
        wrap.className = 'eg-option';

        const label = document.createElement('label');
        label.className = 'eg-option__label';
        label.textContent = optionName;

        const valuesWrap = document.createElement('div');

        if (optionName.toLowerCase().includes('color') || optionName.toLowerCase().includes('colour')) {
          valuesWrap.className = 'eg-colors';

          values.slice(0, 2).forEach(function (value) {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'eg-color';
            btn.textContent = value;

            const colorMap = {
              White: '#fff',
              Black: '#000',
              Grey: '#b8b8b8',
              Gray: '#b8b8b8',
              Red: '#c90035',
              Blue: '#1f57c8'
            };

            btn.style.setProperty('--swatch-color', colorMap[value] || '#000');

            if (selectedOptions[optionIndex] === value) {
              btn.classList.add('is-selected');
            }

            btn.addEventListener('click', function () {
              selectedOptions[optionIndex] = value;

              valuesWrap.querySelectorAll('button').forEach(function (item) {
                item.classList.remove('is-selected');
              });

              btn.classList.add('is-selected');
              updatePrice();
            });

            valuesWrap.appendChild(btn);
          });
        } else if (optionName.toLowerCase().includes('size')) {
          valuesWrap.className = 'eg-size-wrap';

          const select = document.createElement('select');
          select.className = 'eg-size';

          const placeholder = document.createElement('option');
          placeholder.textContent = 'Choose your size';
          placeholder.value = '';
          select.appendChild(placeholder);

          values.forEach(function (value) {
            const option = document.createElement('option');
            option.value = value;
            option.textContent = value;
            select.appendChild(option);
          });

          select.addEventListener('change', function () {
            if (select.value) {
              selectedOptions[optionIndex] = select.value;
              updatePrice();
            }
          });

          valuesWrap.appendChild(select);
        }

        wrap.appendChild(label);
        wrap.appendChild(valuesWrap);
        optionsBox.appendChild(wrap);
      });
    }

    async function loadProduct(handle) {
      if (!handle) return;

      try {
        if (message) message.textContent = 'Loading...';

        const res = await fetch('/products/' + handle + '.js');
        currentProduct = await res.json();

        selectedOptions = currentProduct.variants[0].options.slice();

        image.src = currentProduct.featured_image || '';
        image.alt = currentProduct.title;
        title.textContent = currentProduct.title;
        price.textContent = money(currentProduct.variants[0].price);
        desc.innerHTML = currentProduct.description || 'This one-piece swimsuit is crafted from jersey featuring an allover micro Monogram motif in relief.';

        renderOptions();
        updatePrice();

        if (message) message.textContent = '';
        openPopup();
      } catch (error) {
        if (message) message.textContent = 'Product could not be loaded.';
      }
    }

    document.addEventListener('click', function (event) {
      const plus = event.target.closest('.eg-grid__plus');

      if (plus) {
        event.preventDefault();
        event.stopPropagation();
        loadProduct(plus.getAttribute('data-handle'));
      }

      if (event.target.closest('[data-close]')) {
        closePopup();
      }
    });

    cartBtn.addEventListener('click', async function () {
      const variant = selectedVariant();

      if (!variant) {
        message.textContent = 'Please select available options.';
        return;
      }

      message.textContent = 'Adding...';

      try {
        await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id: variant.id,
            quantity: 1
          })
        });

        message.textContent = 'Added to cart.';
      } catch (error) {
        message.textContent = 'Could not add to cart.';
      }
    });
  }

  initEgGrid();

  document.addEventListener('shopify:section:load', function () {
    initEgGrid();
  });
})();
</script>

{% schema %}
{
  "name": "Custom Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Choose product"
        },
        {
          "type": "range",
          "id": "plus_x",
          "label": "Plus icon horizontal position",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 64
        },
        {
          "type": "range",
          "id": "plus_y",
          "label": "Plus icon vertical position",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 16
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom Grid"
    }
  ]
}
{% endschema %}
