<section class="eg-grid" id="EgGrid-{{ section.id }}">
  <h2>{{ section.settings.heading }}</h2>

  <div class="eg-grid__items">
    {% for block in section.blocks %}
      {% assign product = block.settings.product %}
      {% if product %}
        <div
          class="eg-grid__card"
          style="--x:{{ block.settings.plus_x }}%; --y:{{ block.settings.plus_y }}%;"
          {{ block.shopify_attributes }}
        >
          <img
            src="{{ product.featured_image | image_url: width: 900 }}"
            alt="{{ product.title }}"
            loading="lazy"
          >

          <button
            type="button"
            class="eg-plus"
            data-handle="{{ product.handle }}"
          >+</button>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <!-- POPUP -->
  <div class="eg-popup" id="EgPopup-{{ section.id }}">
    <div class="eg-overlay"></div>

    <div class="eg-popup-box">
      <button class="eg-close">×</button>

      <div class="eg-top">
        <img class="eg-img" src="" alt="">
        <div>
          <h3 class="eg-title"></h3>
          <p class="eg-price"></p>
          <div class="eg-desc"></div>
        </div>
      </div>

      <div class="eg-options"></div>

      <button class="eg-cart">
        ADD TO CART <span>→</span>
      </button>

      <p class="eg-msg"></p>
    </div>
  </div>
</section>

<style>
/* GRID */
.eg-grid{
  max-width:1440px;
  margin:auto;
  padding:80px 176px;
  font-family:Georgia,serif;
}
.eg-grid h2{
  margin-bottom:40px;
  font-size:32px;
  font-weight:400;
}
.eg-grid__items{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:16px;
}
.eg-grid__card{
  position:relative;
  aspect-ratio:1/1.28;
  overflow:hidden;
}
.eg-grid__card img{
  width:100%;
  height:100%;
  object-fit:cover;
}
.eg-plus{
  position:absolute;
  left:var(--x);
  top:var(--y);
  transform:translate(-50%,-50%);
  width:20px;
  height:20px;
  border-radius:50%;
  border:0;
  background:#f8f3df;
  font-size:16px;
  cursor:pointer;
}

/* POPUP */
.eg-popup{
  position:fixed;
  inset:0;
  display:none;
  z-index:99999;
}
.eg-popup.active{
  display:block;
}
.eg-overlay{
  position:absolute;
  inset:0;
  background:rgba(0,0,0,.18);
}
.eg-popup-box{
  position:relative;
  background:#fff;
  width:390px;
  margin:24px auto;
  padding:24px;
  border:1px solid #000;
  z-index:2;
}
.eg-close{
  position:absolute;
  top:10px;
  right:14px;
  font-size:26px;
  border:0;
  background:none;
  cursor:pointer;
}
.eg-top{
  display:grid;
  grid-template-columns:140px 1fr;
  gap:12px;
}
.eg-img{
  width:140px;
  height:170px;
  object-fit:cover;
}
.eg-title{font-size:18px;margin:0 0 8px}
.eg-price{font-size:18px;margin:0 0 8px}
.eg-desc{font-size:14px;max-height:80px;overflow:hidden}

.eg-cart{
  width:100%;
  height:56px;
  margin-top:28px;
  background:#000;
  color:#fff;
  border:0;
  display:flex;
  justify-content:center;
  align-items:center;
  gap:40px;
  cursor:pointer;
}
.eg-cart span{font-size:30px}
.eg-msg{font-size:13px;margin-top:8px}

/* MOBILE */
@media(max-width:749px){
  .eg-grid{padding:40px 20px}
  .eg-grid__items{grid-template-columns:repeat(2,1fr);gap:4px}
  .eg-popup-box{width:calc(100% - 32px)}
}
</style>

<script>
(function(){
  const root=document.getElementById('EgGrid-{{ section.id }}');
  const popup=root.querySelector('.eg-popup');
  const img=popup.querySelector('.eg-img');
  const title=popup.querySelector('.eg-title');
  const price=popup.querySelector('.eg-price');
  const desc=popup.querySelector('.eg-desc');
  const optionsBox=popup.querySelector('.eg-options');
  const cartBtn=popup.querySelector('.eg-cart');
  const msg=popup.querySelector('.eg-msg');

  let product=null, selected=[];

  function money(c){
    return (c/100).toLocaleString(undefined,{
      style:'currency',
      currency:'{{ cart.currency.iso_code }}'
    });
  }

  function open(){
    popup.classList.add('active');
    document.body.style.overflow='hidden';
  }
  function close(){
    popup.classList.remove('active');
    document.body.style.overflow='';
    msg.textContent='';
  }

  root.addEventListener('click',async e=>{
    if(e.target.classList.contains('eg-plus')){
      const handle=e.target.dataset.handle;
      open();
      const res=await fetch(`/products/${handle}.js`);
      product=await res.json();
      selected=product.variants[0].options.slice();

      img.src=product.featured_image;
      title.textContent=product.title;
      price.textContent=money(product.variants[0].price);
      desc.innerHTML=product.description;

      optionsBox.innerHTML='';
      product.options.forEach((name,i)=>{
        const wrap=document.createElement('div');
        const label=document.createElement('label');
        label.textContent=name;
        const select=document.createElement('select');

        [...new Set(product.variants.map(v=>v.options[i]))]
        .forEach(v=>{
          const o=document.createElement('option');
          o.value=v;o.textContent=v;
          select.appendChild(o);
        });

        select.onchange=()=>selected[i]=select.value;
        wrap.append(label,select);
        optionsBox.appendChild(wrap);
      });
    }

    if(e.target.classList.contains('eg-overlay') || e.target.classList.contains('eg-close')){
      close();
    }
  });

  cartBtn.onclick=async()=>{
    const variant=product.variants.find(v =>
      v.options.every((o,i)=>o===selected[i])
    );
    if(!variant){msg.textContent='Select options';return;}

    await fetch('/cart/add.js',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({id:variant.id,quantity:1})
    });
    msg.textContent='Added to cart';
  };

  document.addEventListener('keydown',e=>{
    if(e.key==='Escape')close();
  });
})();
</script>

{% schema %}
{
  "name":"Custom Grid Popup",
  "settings":[
    { "type":"text","id":"heading","label":"Heading","default":"Tisso vison in the wild" }
  ],
  "blocks":[
    {
      "type":"product",
      "name":"Product",
      "settings":[
        { "type":"product","id":"product","label":"Product" },
        { "type":"range","id":"plus_x","min":0,"max":100,"step":1,"default":64,"label":"Plus X" },
        { "type":"range","id":"plus_y","min":0,"max":100,"step":1,"default":16,"label":"Plus Y" }
      ]
    }
  ],
  "max_blocks":6,
  "presets":[{ "name":"Custom Grid Popup" }]
}
{% endschema %}
