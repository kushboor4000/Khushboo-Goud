<section class="eg-grid">
  <h2>{{ section.settings.heading }}</h2>

  <div class="eg-grid__items">
    {% for block in section.blocks %}
      {% assign product = block.settings.product %}

      {% if product != blank %}
        <div
          class="eg-grid__card"
          {{ block.shopify_attributes }}
          style="
            --plus-x: {{ block.settings.plus_x }}%;
            --plus-y: {{ block.settings.plus_y }}%;
            --plus-x-mobile: {{ block.settings.plus_x_mobile }}%;
            --plus-y-mobile: {{ block.settings.plus_y_mobile }}%;
          "
        >
          <img
            src="{{ product.featured_image | image_url: width: 900 }}"
            alt="{{ product.title | escape }}"
            width="900"
            height="1100"
            loading="lazy"
          >

          <button
            type="button"
            class="eg-grid__plus"
            data-handle="{{ product.handle }}"
            aria-label="Open {{ product.title | escape }}"
          >
            +
          </button>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="eg-popup" id="EgPopup">
    <div class="eg-popup__overlay" data-close></div>

    <div class="eg-popup__box">
      <button type="button" class="eg-popup__close" data-close>×</button>

      <div class="eg-popup__top">
        <img id="EgImage" src="" alt="" width="120" height="150">

        <div class="eg-popup__info">
          <h3 id="EgTitle"></h3>
          <p id="EgPrice"></p>
          <div id="EgDesc"></div>
        </div>
      </div>

      <div id="EgOptions"></div>

      <button type="button" id="EgCartBtn" class="eg-popup__cart">
        ADD TO CART
      </button>

      <p id="EgMessage"></p>
    </div>
  </div>
</section>

<style>
.eg-grid {
  max-width: 1440px;
  margin: 0 auto;
  padding: 55px 50px;
  font-family: Arial, sans-serif;
}

.eg-grid h2 {
  font-size: 32px;
  margin: 0 0 28px;
  font-weight: 500;
  text-align: center;
}

.eg-grid__items {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.eg-grid__card {
  position: relative;
  background: #f4f4f4;
  overflow: hidden;
}

.eg-grid__card img {
  width: 100%;
  height: 430px;
  object-fit: cover;
  display: block;
}

.eg-grid__plus {
  position: absolute;
  top: var(--plus-y);
  left: var(--plus-x);
  transform: translate(-50%, -50%);
  width: 22px;
  height: 22px;
  border: 0;
  border-radius: 50%;
  background: #fff;
  color: #000;
  font-size: 18px;
  line-height: 19px;
  cursor: pointer;
  padding: 0;
  z-index: 3;
}

/* Popup */
.eg-popup {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 99999;
}

.eg-popup.is-open {
  display: block;
}

.eg-popup__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.eg-popup__box {
  position: relative;
  z-index: 2;
  background: #fff;
  width: 315px;
  max-width: calc(100vw - 24px);
  margin: 55px auto;
  padding: 20px;
  border: 1px solid #000;
  box-sizing: border-box;
}

.eg-popup__close {
  position: absolute;
  top: 10px;
  right: 14px;
  background: transparent;
  border: 0;
  font-size: 26px;
  line-height: 1;
  cursor: pointer;
  padding: 0;
  color: #000;
}

.eg-popup__top {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 10px;
  align-items: start;
}

.eg-popup__top img {
  width: 120px;
  height: 150px;
  object-fit: cover;
  display: block;
}

.eg-popup__info {
  padding-top: 18px;
}

.eg-popup h3 {
  margin: 0 18px 12px 0;
  font-size: 16px;
  line-height: 1.2;
  font-weight: 400;
  color: #000;
}

#EgPrice {
  margin: 0 0 12px;
  font-size: 16px;
  line-height: 1.2;
  color: #000;
}

#EgDesc {
  font-size: 12px;
  line-height: 1.15;
  color: #000;
  max-height: 58px;
  overflow: hidden;
}

.eg-option {
  margin-top: 12px;
}

.eg-option label {
  display: block;
  font-size: 13px;
  font-weight: 400;
  margin-bottom: 6px;
  color: #000;
}

.eg-option__values {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  border: 1px solid #777;
}

.eg-option button {
  min-height: 40px;
  border: 0;
  border-right: 1px solid #777;
  background: #fff;
  color: #000;
  padding: 9px 12px;
  font-size: 16px;
  text-align: left;
  cursor: pointer;
}

.eg-option button:last-child {
  border-right: 0;
}

.eg-option button.is-selected {
  box-shadow: inset 5px 0 0 #000;
}

.eg-option select {
  width: 100%;
  height: 40px;
  border: 1px solid #777;
  background: #fff;
  color: #000;
  padding: 0 12px;
  font-size: 15px;
}

.eg-popup__cart {
  width: 100%;
  height: 45px;
  margin-top: 18px;
  background: #000;
  color: #fff;
  border: 0;
  font-size: 14px;
  font-weight: 400;
  cursor: pointer;
  letter-spacing: 0.2px;
}

.eg-popup__cart::after {
  content: " →";
  font-size: 28px;
  margin-left: 28px;
  vertical-align: -3px;
}

#EgMessage {
  margin: 8px 0 0;
  font-size: 12px;
  line-height: 1.3;
  color: #000;
}

@media (max-width: 749px) {
  .eg-grid {
    padding: 38px 0;
  }

  .eg-grid h2 {
    font-size: 26px;
    padding: 0 16px;
  }

  .eg-grid__items {
    grid-template-columns: repeat(2, 1fr);
    gap: 3px;
  }

  .eg-grid__card img {
    height: 230px;
  }

  .eg-grid__plus {
    top: var(--plus-y-mobile);
    left: var(--plus-x-mobile);
    width: 20px;
    height: 20px;
    font-size: 16px;
    line-height: 18px;
  }

  .eg-popup__box {
    width: 315px;
    max-width: calc(100vw - 24px);
    margin: 24px auto;
    max-height: 92vh;
    overflow-y: auto;
  }
}
</style>

<script>
(function () {
  const popup = document.getElementById('EgPopup');
  const image = document.getElementById('EgImage');
  const title = document.getElementById('EgTitle');
  const price = document.getElementById('EgPrice');
  const desc = document.getElementById('EgDesc');
  const optionsBox = document.getElementById('EgOptions');
  const cartBtn = document.getElementById('EgCartBtn');
  const message = document.getElementById('EgMessage');

  let currentProduct = null;
  let selectedOptions = [];

  function money(cents) {
    return (cents / 100).toLocaleString('en-US', {
      style: 'currency',
      currency: '{{ cart.currency.iso_code }}'
    });
  }

  function openPopup() {
    popup.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closePopup() {
    popup.classList.remove('is-open');
    document.body.style.overflow = '';
    message.textContent = '';
  }

  function selectedVariant() {
    if (!currentProduct) return null;

    return currentProduct.variants.find(function (variant) {
      return variant.options.every(function (value, index) {
        return value === selectedOptions[index];
      });
    });
  }

  function updatePrice() {
    const variant = selectedVariant();
    if (variant) {
      price.textContent = money(variant.price);
    }
  }

  function renderOptions() {
    optionsBox.innerHTML = '';

    if (!currentProduct || !currentProduct.options) return;

    currentProduct.options.forEach(function (optionName, optionIndex) {
      const values = [];

      currentProduct.variants.forEach(function (variant) {
        const value = variant.options[optionIndex];
        if (value && !values.includes(value)) values.push(value);
      });

      const wrap = document.createElement('div');
      wrap.className = 'eg-option';

      const label = document.createElement('label');
      label.textContent = optionName;

      wrap.appendChild(label);

      if (optionName.toLowerCase().includes('size')) {
        const select = document.createElement('select');

        values.forEach(function (value) {
          const option = document.createElement('option');
          option.value = value;
          option.textContent = value;
          if (selectedOptions[optionIndex] === value) {
            option.selected = true;
          }
          select.appendChild(option);
        });

        select.addEventListener('change', function () {
          selectedOptions[optionIndex] = select.value;
          updatePrice();
        });

        wrap.appendChild(select);
      } else {
        const valuesWrap = document.createElement('div');
        valuesWrap.className = 'eg-option__values';

        values.forEach(function (value) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.textContent = value;

          if (selectedOptions[optionIndex] === value) {
            btn.classList.add('is-selected');
          }

          btn.addEventListener('click', function () {
            selectedOptions[optionIndex] = value;

            valuesWrap.querySelectorAll('button').forEach(function (item) {
              item.classList.remove('is-selected');
            });

            btn.classList.add('is-selected');
            updatePrice();
          });

          valuesWrap.appendChild(btn);
        });

        wrap.appendChild(valuesWrap);
      }

      optionsBox.appendChild(wrap);
    });
  }

  async function loadProduct(handle) {
    message.textContent = 'Loading...';
    openPopup();

    try {
      const root = window.Shopify && window.Shopify.routes && window.Shopify.routes.root
        ? window.Shopify.routes.root
        : '/';

      const res = await fetch(root + 'products/' + handle + '.js');

      if (!res.ok) {
        throw new Error('Product fetch failed');
      }

      currentProduct = await res.json();

      if (!currentProduct || !currentProduct.variants || !currentProduct.variants.length) {
        throw new Error('No variants found');
      }

      selectedOptions = currentProduct.variants[0].options.slice();

      image.src = currentProduct.featured_image || '';
      image.alt = currentProduct.title || '';
      title.textContent = currentProduct.title || '';
      desc.innerHTML = currentProduct.description || '';

      renderOptions();
      updatePrice();

      message.textContent = '';
    } catch (error) {
      message.textContent = 'Product could not be loaded.';
    }
  }

  async function addSoftWinterJacket() {
    try {
      const root = window.Shopify && window.Shopify.routes && window.Shopify.routes.root
        ? window.Shopify.routes.root
        : '/';

      const res = await fetch(root + 'products/soft-winter-jacket.js');

      if (!res.ok) return;

      const jacket = await res.json();

      if (!jacket.variants || !jacket.variants[0]) return;

      await fetch(root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: jacket.variants[0].id,
          quantity: 1
        })
      });
    } catch (error) {
      console.log('Soft Winter Jacket not found');
    }
  }

  document.querySelectorAll('.eg-grid__plus').forEach(function (btn) {
    btn.addEventListener('click', function () {
      loadProduct(btn.dataset.handle);
    });
  });

  document.querySelectorAll('[data-close]').forEach(function (btn) {
    btn.addEventListener('click', closePopup);
  });

  document.addEventListener('keydown', function (event) {
    if (event.key === 'Escape') {
      closePopup();
    }
  });

  cartBtn.addEventListener('click', async function () {
    const variant = selectedVariant();

    if (!variant) {
      message.textContent = 'Please select available options.';
      return;
    }

    message.textContent = 'Adding...';

    try {
      const root = window.Shopify && window.Shopify.routes && window.Shopify.routes.root
        ? window.Shopify.routes.root
        : '/';

      await fetch(root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: variant.id,
          quantity: 1
        })
      });

      if (selectedOptions.includes('Black') && selectedOptions.includes('Medium')) {
        await addSoftWinterJacket();
      }

      message.textContent = 'Added to cart.';
    } catch (error) {
      message.textContent = 'Could not add to cart.';
    }
  });
})();
</script>

{% schema %}
{
  "name": "Custom Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Choose product"
        },
        {
          "type": "range",
          "id": "plus_x",
          "label": "Plus icon horizontal position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 55
        },
        {
          "type": "range",
          "id": "plus_y",
          "label": "Plus icon vertical position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 55
        },
        {
          "type": "range",
          "id": "plus_x_mobile",
          "label": "Mobile plus icon horizontal position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 55
        },
        {
          "type": "range",
          "id": "plus_y_mobile",
          "label": "Mobile plus icon vertical position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 55
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom Grid"
    }
  ]
}
{% endschema %}
