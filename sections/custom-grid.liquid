<section class="eg-grid">
  <h2>{{ section.settings.heading }}</h2>

  <div class="eg-grid__items">
    {% for block in section.blocks %}
      {% assign product = block.settings.product %}
      {% if product != blank %}
        <div class="eg-grid__card" {{ block.shopify_attributes }}>
          <img
            src="{{ product.featured_image | image_url: width: 700 }}"
            alt="{{ product.title | escape }}"
            width="700"
            height="850"
            loading="lazy"
          >

          <button
            type="button"
            class="eg-grid__plus"
            data-handle="{{ product.handle }}"
            aria-label="Open product"
          >
            +
          </button>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="eg-popup" id="EgPopup">
    <div class="eg-popup__overlay" data-close></div>

    <div class="eg-popup__box">
      <button type="button" class="eg-popup__close" data-close>×</button>

      <div class="eg-popup__top">
        <img id="EgImage" src="" alt="" width="116" height="140">

        <div class="eg-popup__content">
          <h3 id="EgTitle"></h3>
          <p id="EgPrice"></p>
          <div id="EgDesc"></div>
        </div>
      </div>

      <div id="EgOptions"></div>

      <button type="button" id="EgCartBtn" class="eg-popup__cart">
        ADD TO CART
      </button>

      <p id="EgMessage"></p>
    </div>
  </div>
</section>

<style>
.eg-grid {
  max-width: 1440px;
  margin: 0 auto;
  padding: 55px 50px;
  font-family: Arial, sans-serif;
}

.eg-grid h2 {
  font-size: 32px;
  margin: 0 0 28px;
  font-weight: 500;
}

.eg-grid__items {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.eg-grid__card {
  position: relative;
  background: #f4f4f4;
  overflow: hidden;
}

.eg-grid__card img {
  width: 100%;
  height: 430px;
  object-fit: cover;
  display: block;
}

.eg-grid__plus {
  position: absolute;
  width: 22px;
  height: 22px;
  border: none;
  border-radius: 50%;
  background: #fff;
  color: #000;
  font-size: 17px;
  line-height: 19px;
  cursor: pointer;
  z-index: 2;
  padding: 0;
}

/* Different plus icon position for every grid card */
.eg-grid__card:nth-child(1) .eg-grid__plus {
  top: 10%;
  right: 18%;
}

.eg-grid__card:nth-child(2) .eg-grid__plus {
  top: 7%;
  right: 15%;
}

.eg-grid__card:nth-child(3) .eg-grid__plus {
  top: 17%;
  right: 34%;
}

.eg-grid__card:nth-child(4) .eg-grid__plus {
  top: 14%;
  right: 22%;
}

.eg-grid__card:nth-child(5) .eg-grid__plus {
  top: 15%;
  right: 38%;
}

.eg-grid__card:nth-child(6) .eg-grid__plus {
  top: 13%;
  right: 28%;
}

.eg-popup {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 99999;
}

.eg-popup.is-open {
  display: block;
}

.eg-popup__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.45);
}

.eg-popup__box {
  position: relative;
  background: #fff;
  width: 315px;
  max-width: calc(100vw - 32px);
  margin: 70px auto;
  padding: 20px;
  z-index: 2;
  box-sizing: border-box;
}

.eg-popup__close {
  position: absolute;
  top: 8px;
  right: 14px;
  background: none;
  border: none;
  font-size: 24px;
  line-height: 1;
  cursor: pointer;
  padding: 0;
}

.eg-popup__top {
  display: grid;
  grid-template-columns: 116px 1fr;
  gap: 10px;
  align-items: start;
}

.eg-popup__top img {
  width: 116px;
  height: 140px;
  object-fit: cover;
  display: block;
}

.eg-popup__content {
  padding-top: 18px;
}

.eg-popup h3 {
  margin: 0 0 12px;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.2;
}

#EgPrice {
  font-size: 16px;
  margin: 0 0 12px;
  line-height: 1.2;
}

#EgDesc {
  font-size: 12px;
  line-height: 1.2;
  margin-bottom: 0;
  max-height: 56px;
  overflow: hidden;
}

.eg-option {
  margin-top: 12px;
  margin-bottom: 14px;
}

.eg-option label {
  display: block;
  font-weight: 400;
  margin-bottom: 6px;
  font-size: 13px;
}

.eg-option__values {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0;
  border: 1px solid #777;
}

.eg-option button {
  border: none;
  border-right: 1px solid #777;
  background: #fff;
  padding: 10px 12px;
  cursor: pointer;
  font-size: 16px;
  text-align: left;
  min-height: 40px;
}

.eg-option button:last-child {
  border-right: none;
}

.eg-option button.is-selected {
  background: #fff;
  color: #000;
  box-shadow: inset 5px 0 0 #000;
}

.eg-popup__cart {
  width: 100%;
  background: #000;
  color: #fff;
  border: none;
  padding: 15px;
  font-weight: 400;
  cursor: pointer;
  font-size: 14px;
  letter-spacing: .2px;
  margin-top: 14px;
}

.eg-popup__cart::after {
  content: " →";
  font-size: 28px;
  margin-left: 28px;
  vertical-align: -3px;
}

#EgMessage {
  font-size: 12px;
  margin: 8px 0 0;
}

@media (max-width: 749px) {
  .eg-grid {
    padding: 38px 0;
  }

  .eg-grid h2 {
    font-size: 26px;
    padding: 0 16px;
  }

  .eg-grid__items {
    grid-template-columns: repeat(2, 1fr);
    gap: 3px;
  }

  .eg-grid__card img {
    height: 190px;
  }

  .eg-grid__plus {
    width: 20px;
    height: 20px;
    font-size: 16px;
    line-height: 18px;
  }

  .eg-grid__card:nth-child(1) .eg-grid__plus {
    top: 9%;
    right: 20%;
  }

  .eg-grid__card:nth-child(2) .eg-grid__plus {
    top: 8%;
    right: 16%;
  }

  .eg-grid__card:nth-child(3) .eg-grid__plus {
    top: 18%;
    right: 34%;
  }

  .eg-grid__card:nth-child(4) .eg-grid__plus {
    top: 13%;
    right: 20%;
  }

  .eg-grid__card:nth-child(5) .eg-grid__plus {
    top: 15%;
    right: 36%;
  }

  .eg-grid__card:nth-child(6) .eg-grid__plus {
    top: 12%;
    right: 28%;
  }

  .eg-popup__box {
    width: 315px;
    max-width: calc(100vw - 24px);
    margin: 28px auto;
    padding: 20px;
    max-height: 92vh;
    overflow-y: auto;
  }

  .eg-popup__top {
    grid-template-columns: 116px 1fr;
    gap: 10px;
  }

  .eg-popup__top img {
    width: 116px;
    height: 140px;
  }
}
</style>

<script>
(function () {
  const popup = document.getElementById('EgPopup');
  const image = document.getElementById('EgImage');
  const title = document.getElementById('EgTitle');
  const price = document.getElementById('EgPrice');
  const desc = document.getElementById('EgDesc');
  const optionsBox = document.getElementById('EgOptions');
  const cartBtn = document.getElementById('EgCartBtn');
  const message = document.getElementById('EgMessage');

  let currentProduct = null;
  let selectedOptions = [];

  function money(cents) {
    return (cents / 100).toLocaleString('en-US', {
      style: 'currency',
      currency: '{{ cart.currency.iso_code }}'
    });
  }

  function openPopup() {
    popup.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closePopup() {
    popup.classList.remove('is-open');
    document.body.style.overflow = '';
    message.textContent = '';
  }

  function selectedVariant() {
    if (!currentProduct) return null;

    return currentProduct.variants.find(function (variant) {
      return variant.options.every(function (value, index) {
        return value === selectedOptions[index];
      });
    });
  }

  function updatePrice() {
    const variant = selectedVariant();
    if (variant) {
      price.textContent = money(variant.price);
    }
  }

  function renderOptions() {
    optionsBox.innerHTML = '';

    currentProduct.options.forEach(function (optionName, optionIndex) {
      const values = [];

      currentProduct.variants.forEach(function (variant) {
        const value = variant.options[optionIndex];
        if (!values.includes(value)) values.push(value);
      });

      const wrap = document.createElement('div');
      wrap.className = 'eg-option';

      const label = document.createElement('label');
      label.textContent = optionName;

      const valuesWrap = document.createElement('div');
      valuesWrap.className = 'eg-option__values';

      values.forEach(function (value) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = value;

        if (selectedOptions[optionIndex] === value) {
          btn.classList.add('is-selected');
        }

        btn.addEventListener('click', function () {
          selectedOptions[optionIndex] = value;

          valuesWrap.querySelectorAll('button').forEach(function (item) {
            item.classList.remove('is-selected');
          });

          btn.classList.add('is-selected');
          updatePrice();
        });

        valuesWrap.appendChild(btn);
      });

      wrap.appendChild(label);
      wrap.appendChild(valuesWrap);
      optionsBox.appendChild(wrap);
    });
  }

  async function loadProduct(handle) {
    message.textContent = 'Loading...';
    openPopup();

    try {
      const res = await fetch('/products/' + handle + '.js');
      currentProduct = await res.json();

      selectedOptions = currentProduct.variants[0].options.slice();

      image.src = currentProduct.featured_image || '';
      image.alt = currentProduct.title;
      title.textContent = currentProduct.title;
      desc.innerHTML = currentProduct.description || '';

      renderOptions();
      updatePrice();

      message.textContent = '';
    } catch (error) {
      message.textContent = 'Product could not be loaded.';
    }
  }

  async function addSoftWinterJacket() {
    try {
      const res = await fetch('/products/soft-winter-jacket.js');
      const jacket = await res.json();

      if (!jacket.variants || !jacket.variants[0]) return;

      await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: jacket.variants[0].id,
          quantity: 1
        })
      });
    } catch (error) {
      console.log('Soft Winter Jacket not found');
    }
  }

  document.querySelectorAll('.eg-grid__plus').forEach(function (btn) {
    btn.addEventListener('click', function () {
      loadProduct(btn.dataset.handle);
    });
  });

  document.querySelectorAll('[data-close]').forEach(function (btn) {
    btn.addEventListener('click', closePopup);
  });

  cartBtn.addEventListener('click', async function () {
    const variant = selectedVariant();

    if (!variant) {
      message.textContent = 'Please select available options.';
      return;
    }

    message.textContent = 'Adding...';

    try {
      await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: variant.id,
          quantity: 1
        })
      });

      if (selectedOptions.includes('Black') && selectedOptions.includes('Medium')) {
        await addSoftWinterJacket();
      }

      message.textContent = 'Added to cart.';
    } catch (error) {
      message.textContent = 'Could not add to cart.';
    }
  });
})();
</script>

{% schema %}
{
  "name": "Custom Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Choose product"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom Grid"
    }
  ]
}
{% endschema %}
